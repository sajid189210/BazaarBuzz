<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-gray-50 antialiased">
    <div class="flex min-h-screen">
        <%- include('../partials/adminSideMenu') %>
        <div class="flex-1 ml-[250px]">
            <header class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 z-40">
                <div class="flex items-center gap-2 text-sm text-gray-500">
                    <a href="/admin/dashboard" class="text-gray-900 font-semibold">Dashboard</a>
                </div>
            </header>
            <main class="p-6 space-y-8">
                <!-- Sales Charts Row -->
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Sales</h2>
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                        <div class="bg-white rounded-xl border border-gray-200 p-4"><div id="salesRevenue_bar"></div></div>
                        <div class="bg-white rounded-xl border border-gray-200 p-4"><div id="salesByBrand"></div></div>
                        <div class="bg-white rounded-xl border border-gray-200 p-4"><div id="AOV"></div></div>
                    </div>
                </div>
                <!-- Customer Chart -->
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Customers</h2>
                    <div class="bg-white rounded-xl border border-gray-200 p-4"><div id="customerChart"></div></div>
                </div>
                <!-- Products Charts -->
                <div>
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Products</h2>
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                        <div class="bg-white rounded-xl border border-gray-200 p-4"><div id="topSellingProductChart"></div></div>
                        <div class="bg-white rounded-xl border border-gray-200 p-4"><div id="inStockChart"></div></div>
                    </div>
                </div>
                <!-- Recent Orders Table -->
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-semibold text-gray-900">Recent Orders</h2>
                        <a href="/admin/orders" class="text-sm font-medium text-rose-500 hover:text-rose-600 transition-colors">View All</a>
                    </div>
                    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="min-w-full text-sm">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">OrderID</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">User Email</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">Total Amount</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">Order Date</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">Order Status</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">Payment Status</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">Return Status</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    <% if(orders && orders.length) { %>
                                    <% orders.forEach(order => { %>
                                    <tr class="hover:bg-gray-50">
                                        <td class="px-4 py-3 text-gray-900 font-medium"><%= order._id %></td>
                                        <td class="px-4 py-3 text-gray-600"><%= order.user?.email || '-' %></td>
                                        <td class="px-4 py-3 text-gray-900">₹<%= order.totalAmount?.toLocaleString() || 0 %></td>
                                        <td class="px-4 py-3 text-gray-600"><%= new Date(order.createdAt).toLocaleDateString('en-IN') %></td>
                                        <td class="px-4 py-3"><span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full <%= order.status === 'Delivered' ? 'bg-green-50 text-green-700' : order.status === 'Cancelled' ? 'bg-red-50 text-red-700' : 'bg-amber-50 text-amber-700' %>"><%= order.status %></span></td>
                                        <td class="px-4 py-3"><span class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full <%= order.paymentStatus === 'Paid' ? 'bg-green-50 text-green-700' : 'bg-amber-50 text-amber-700' %>"><%= order.paymentStatus %></span></td>
                                        <td class="px-4 py-3 text-gray-600"><%= order.returnStatus || 'N/A' %></td>
                                        <td class="px-4 py-3"><a href="/admin/viewOrder/<%= order._id %>" class="text-xs font-medium text-rose-500 hover:text-rose-600">View</a></td>
                                    </tr>
                                    <% }) %>
                                    <% } else { %>
                                    <tr><td colspan="8" class="px-4 py-8 text-center text-gray-400">No orders yet</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>
    <script src="/javascript/admin/dashboard.js"></script>
</body>
</html>
