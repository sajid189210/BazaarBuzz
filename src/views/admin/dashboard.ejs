
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Dashboard</h1>
    </div>
    <div>
        <h2 class="text-base sm:text-lg font-semibold text-gray-900 mb-4">Sales</h2>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <div class="bg-white rounded-xl border border-gray-200 p-4">
                <div id="salesRevenue_bar"></div>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-4">
                <div id="salesByBrand"></div>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-4">
                <div id="AOV"></div>
            </div>
        </div>
    </div>
    <div>
        <h2 class="text-base sm:text-lg font-semibold text-gray-900 mb-4">Customers</h2>
        <div class="bg-white rounded-xl border border-gray-200 p-4">
            <div id="customerChart"></div>
        </div>
    </div>
    <div>
        <h2 class="text-base sm:text-lg font-semibold text-gray-900 mb-4">Products</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="bg-white rounded-xl border border-gray-200 p-4">
                <div id="topSellingProductChart"></div>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-4">
                <div id="ordersByStatusChart"></div>
            </div>
        </div>
    </div>
    <div>
        <h2 class="text-base sm:text-lg font-semibold text-gray-900 mb-4">Orders</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="bg-white rounded-xl border border-gray-200 p-4">
                <div id="paymentMethodSplitChart"></div>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-4">
                <div id="monthlyOrderCountChart"></div>
            </div>
        </div>
    </div>

    <script>
        const dashboardData = {
            salesData: <%- JSON.stringify(salesData) %>,
            revenueByBrand: <%- JSON.stringify(revenueByBrand) %>,
            aovData: <%- JSON.stringify(aovData) %>,
            newCustomer: <%- JSON.stringify(newCustomer) %>,
            repeatedCustomer: <%- JSON.stringify(repeatedCustomer) %>,
            clvData: <%- JSON.stringify(clvData) %>,
            topProducts: <%- JSON.stringify(topProducts) %>,
            ordersByStatus: <%- JSON.stringify(ordersByStatus) %>,
            paymentMethodSplit: <%- JSON.stringify(paymentMethodSplit) %>,
            monthlyOrderCount: <%- JSON.stringify(monthlyOrderCount) %>
        };
    </script>
    <% blocks.scripts=` <script src="/javascript/admin/dashboard.js">
        </script>` %>