<!DOCTYPE html><html lang="en"><head>    <meta charset="UTF-8">    <meta name="viewport" content="width=device-width, initial-scale=1.0">    <title>Admin — Change Password</title>    <link rel="stylesheet" href="/css/style.css">    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon"></head><body class="min-h-screen bg-gray-50 antialiased">    <div class="min-h-screen flex flex-col">        <header class="border-b bg-white px-6 py-4">            <a href="/admin/signIn" class="text-xl font-bold text-gray-900">Bazaar<span class="text-rose-500">Buzz</span><span class="text-xs text-gray-400 ml-2 font-normal">Admin</span></a>        </header>        <div class="flex-1 flex items-center justify-center px-4">            <form action="/admin/ChangePassword" method="POST" class="w-full max-w-sm">                <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">                    <h1 class="text-2xl font-bold text-gray-900">Change Password</h1>                    <% if(message && message.error) { %>                    <div class="mt-4 text-sm text-red-600 bg-red-50 rounded-lg px-4 py-2"><%= message.error %></div>                    <% } %>                    <div class="mt-6 space-y-4">                        <div>                            <label class="block text-sm font-medium text-gray-700">Email</label>                            <input type="email" name="email" required                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />                        </div>                        <div>                            <label class="block text-sm font-medium text-gray-700">Old Password</label>                            <input type="password" name="oldPassword" required                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />                        </div>                        <div>                            <label class="block text-sm font-medium text-gray-700">New Password</label>                            <input type="password" name="newPassword" required                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />                        </div>                        <div>                            <label class="block text-sm font-medium text-gray-700">Confirm Password</label>                            <input type="password" name="confirmPassword" required                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />                        </div>                        <button type="submit" onclick="passwordReset()"                            class="w-full rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">Reset Password</button>                        <a href="/admin/signIn" class="block text-center text-xs text-rose-500 hover:text-rose-600 transition-colors">Back to Sign In</a>                    </div>                </div>            </form>        </div>    </div></body></html>