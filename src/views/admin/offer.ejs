<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — Offers</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-50 antialiased">
    <div class="flex min-h-screen"> <%- include('../partials/adminSideMenu') %>
            <div class="flex-1 ml-0 lg:ml-[250px] min-w-0 transition-margin duration-300">
                <header class="sticky top-0 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 sm:py-4 z-40">
                        <div class="flex items-center gap-3">
                            <button id="adminSidebarToggle"
                                class="lg:hidden inline-flex items-center justify-center w-9 h-9 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
                                type="button">
                                <i class="fa-solid fa-bars"></i>
                            </button>
                            <span class="text-lg font-bold text-gray-900 sm:hidden">Bazaar<span class="text-rose-500">Buzz</span></span>
                            <div class="hidden sm:flex items-center gap-2 text-sm text-gray-500 min-w-0"> <a href="/admin/dashboard"
                                class="hover:text-gray-700 shrink-0">Dashboard</a> <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i> <span class="text-gray-900 font-semibold">Offers</span> </div>
                    </div>
                </header>
                <main class="p-4 sm:p-6">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h1 class="text-xl sm:text-2xl font-bold text-gray-900 flex items-center gap-2"><i class="fa-solid fa-percent text-gray-400 text-lg sm:text-xl"></i>Offers</h1>
                            <p class="text-sm text-gray-500 mt-1">Manage brand offers and discounts</p>
                        </div>
                        <button onclick="openCreateOfferModal()"
                            class="rounded-lg bg-gray-900 hover:bg-gray-800 px-4 sm:px-5 py-2 sm:py-2.5 text-xs sm:text-sm font-semibold text-white transition-colors flex items-center gap-1.5 sm:gap-2 shrink-0">
                            <i class="fa-solid fa-plus"></i>
                            <span>Create Offer</span>
                        </button>
                    </div>

                    <form method="GET" action="/admin/offer">
                        <div class="bg-white rounded-xl border border-gray-200 p-4 mb-6 shadow-sm">
                            <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center flex-wrap">
                                <div class="relative w-full sm:w-44">
                                    <select name="status"
                                        class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all bg-white">
                                        <option value="">All Status</option>
                                        <option value="active" <%= statusFilter==='active' ? 'selected' : '' %>>Active</option>
                                        <option value="inactive" <%= statusFilter==='inactive' ? 'selected' : '' %>>Inactive</option>
                                    </select>
                                </div>
                                <div class="relative w-full sm:w-44">
                                    <select name="category"
                                        class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all bg-white">
                                        <option value="">All Categories</option>
                                        <% (categories || []).forEach(c => { %>
                                            <option value="<%= c.title %>" <%= categoryFilter===c.title ? 'selected' : '' %>><%= c.title %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="relative w-full sm:w-52">
                                    <input type="text" name="search" placeholder="Search by offer or brand name..."
                                        value="<%= search %>"
                                        class="w-full px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all">
                                </div>
                                <div class="flex gap-2 w-full sm:w-auto">
                                    <button type="submit"
                                        class="rounded-lg bg-rose-500 hover:bg-rose-600 px-5 py-2 text-sm font-semibold text-white transition-colors">Search</button>
                                    <% if (search || statusFilter || categoryFilter) { %>
                                        <a href="/admin/offer"
                                            class="rounded-lg border border-gray-300 hover:bg-gray-50 px-5 py-2 text-sm font-semibold text-gray-700 transition-colors">Clear</a>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </form>

                    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
                        <div class="overflow-x-auto">
                            <table class="min-w-full text-sm">
                                <thead class="bg-gray-50/80">
                                    <tr>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">Offer Name</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider hidden md:table-cell">Brand Name</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider hidden md:table-cell">Category</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">Discount</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider hidden md:table-cell">Created</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">Status</th>
                                        <th class="text-right px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-50">
                                    <% if(offers && offers.length > 0) { %>
                                        <% offers.forEach(offer => { %>
                                            <tr class="hover:bg-gray-50/50 transition-colors">
                                                <td class="px-5 py-4 text-gray-900 font-medium"><%= offer.offerName %></td>
                                                <td class="px-5 py-4 text-gray-600 hidden md:table-cell"><%= offer.brandName || '-' %></td>
                                                <td class="px-5 py-4 text-gray-600 hidden md:table-cell"><%= offer.category?.title || '-' %></td>
                                                <td class="px-5 py-4 text-gray-900 font-medium"><%= offer.discount %>%</td>
                                                <td class="px-5 py-4 text-gray-500 text-sm hidden md:table-cell">
                                                    <%= new Date(offer.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                                </td>
                                                <td class="px-5 py-4">
                                                    <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full <%= offer.isActive ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-rose-50 text-rose-700 border border-rose-200' %>">
                                                        <span class="w-1.5 h-1.5 rounded-full <%= offer.isActive ? 'bg-emerald-500' : 'bg-rose-500' %>"></span>
                                                        <%= offer.isActive ? 'Active' : 'Inactive' %>
                                                    </span>
                                                </td>
                                                <td class="px-5 py-4 text-right">
                                                    <div class="flex items-center justify-end gap-1.5">
                                                        <button onclick="editOffer('<%= offer._id %>')"
                                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors">
                                                            <i class="fa-solid fa-pen-to-square"></i>
                                                            Edit
                                                        </button>
                                                        <button onclick="toggleOffer('<%= offer._id %>')"
                                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg transition-colors <%= offer.isActive ? 'text-rose-600 hover:text-rose-700 hover:bg-rose-50' : 'text-emerald-600 hover:text-emerald-700 hover:bg-emerald-50' %>">
                                                            <i class="fa-solid <%= offer.isActive ? 'fa-ban' : 'fa-check-circle' %>"></i>
                                                            <%= offer.isActive ? 'Block' : 'Unblock' %>
                                                        </button>
                                                        <button onclick="deleteOffer('<%= offer._id %>')"
                                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-red-500 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                                                            <i class="fa-solid fa-trash"></i>
                                                            Delete
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="px-5 py-12 text-center">
                                                <div class="flex flex-col items-center gap-2">
                                                    <i class="fa-regular fa-gem text-4xl text-gray-300"></i>
                                                    <span class="text-gray-400 text-sm">No offers found</span>
                                                </div>
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                        <nav class="mt-8 flex items-center justify-center gap-2" aria-label="Pagination">
                            <a href="<%= currentPage > 1 ? '?page=' + (currentPage - 1) + (search ? '&search=' + encodeURIComponent(search) : '') + (statusFilter ? '&status=' + encodeURIComponent(statusFilter) : '') + (categoryFilter ? '&category=' + encodeURIComponent(categoryFilter) : '') : '#' %>"
                                class="px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors <%= currentPage === 1 ? 'opacity-50 pointer-events-none' : '' %>"
                                <%= currentPage === 1 ? 'aria-disabled="true"' : '' %>>
                                <i class="fa-solid fa-chevron-left"></i>
                                <span class="hidden sm:inline ml-1">Previous</span>
                            </a>
                            <div class="flex items-center gap-1">
                                <% var startPage = Math.max(1, currentPage - 2); var endPage = Math.min(totalPages, currentPage + 2); if (endPage - startPage < 4) { if (startPage === 1) { endPage = Math.min(totalPages, startPage + 4); } else if (endPage === totalPages) { startPage = Math.max(1, endPage - 4); } } %>
                                <% for (var i = startPage; i <= endPage; i++) { %>
                                    <a href="?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) : '' %><%= statusFilter ? '&status=' + encodeURIComponent(statusFilter) : '' %><%= categoryFilter ? '&category=' + encodeURIComponent(categoryFilter) : '' %>"
                                        class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors <%= i === currentPage ? 'bg-rose-500 text-white' : 'text-gray-700 hover:bg-gray-100' %>"
                                        <%= i === currentPage ? 'aria-current="page"' : '' %>><%= i %></a>
                                <% } %>
                            </div>
                            <a href="<%= currentPage < totalPages ? '?page=' + (currentPage + 1) + (search ? '&search=' + encodeURIComponent(search) : '') + (statusFilter ? '&status=' + encodeURIComponent(statusFilter) : '') + (categoryFilter ? '&category=' + encodeURIComponent(categoryFilter) : '') : '#' %>"
                                class="px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors <%= currentPage === totalPages ? 'opacity-50 pointer-events-none' : '' %>"
                                <%= currentPage === totalPages ? 'aria-disabled="true"' : '' %>>
                                <span class="hidden sm:inline mr-1">Next</span>
                                <i class="fa-solid fa-chevron-right"></i>
                            </a>
                        </nav>
                        <div class="mt-4 text-center text-sm text-gray-500">
                            Page <%= currentPage %> of <%= totalPages %>
                        </div>
                    <% } %>
                </main>
            </div>
    </div>
    <script>
        (function() {
            var toggle = document.getElementById('adminSidebarToggle');
            var sidebar = document.getElementById('adminSidebar');
            var overlay = document.getElementById('adminSidebarOverlay');
            var close = document.getElementById('adminSidebarClose');
            if (!toggle || !sidebar) return;
            function open() { sidebar.classList.remove('-translate-x-full'); if (overlay) overlay.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
            function closeSidebar() { sidebar.classList.add('-translate-x-full'); if (overlay) overlay.classList.add('hidden'); document.body.style.overflow = ''; }
            toggle.addEventListener('click', open);
            if (close) close.addEventListener('click', closeSidebar);
            if (overlay) overlay.addEventListener('click', closeSidebar);
            window.addEventListener('resize', function() { if (window.innerWidth >= 1024) { sidebar.classList.remove('-translate-x-full'); if (overlay) overlay.classList.add('hidden'); document.body.style.overflow = ''; } });
        })();
    </script>
    <script id="categoriesData" type="application/json"><%- JSON.stringify(categories || []) %></script>
    <script id="offersData" type="application/json"><%- JSON.stringify(offers || []) %></script>
    <script src="/javascript/admin/offer.js"></script>
</body>

</html>