<% blocks.head = [
    '<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">',
    '<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"><\/script>',
    '<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">',
    '<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"><\/script>',
].join('\n'); %><% blocks.breadcrumb = [
    '<a href="/admin/productList" class="hover:text-gray-700">Products</a>',
    '<i class="fa-solid fa-chevron-right text-xs text-gray-400"></i>',
    '<span class="text-gray-900 font-semibold">Create Product</span>',
].join(' '); %><div class="max-w-4xl mx-auto">
            <div class="bg-white rounded-xl border border-gray-200 p-8">
                <form action="/admin/productList/create" method="POST" id="productDetailForm">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div> <label for="productName" class="block text-sm font-medium text-gray-700">Product
                                Name</label> <input type="text" id="productName" name="productName"
                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                            <span class="error-msg text-red-500 text-xs mt-1 hidden"></span> </div>
                        <div> <label for="brand" class="block text-sm font-medium text-gray-700">Brand</label> <select
                                id="brand" name="brand"
                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all"
                                disabled>
                                <option value="">Select category first</option>
                            </select> <span class="error-msg text-red-500 text-xs mt-1 hidden"></span> </div>
                        <div> <label for="category" class="block text-sm font-medium text-gray-700">Category</label>
                            <select id="category" name="category"
                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all">
                                <option value="">Select</option>
                                <% if(Category && Category.length> 0) { Category.forEach(cat => { %> <option
                                        value="<%= cat._id %>">
                                        <%= cat.title %>
                                    </option>
                                    <% }) } %>
                            </select> <span class="error-msg text-red-500 text-xs mt-1 hidden"></span> </div>
                        <div> <label for="productPrice" class="block text-sm font-medium text-gray-700">Price
                                (₹)</label> <input type="number" id="productPrice" name="productPrice" step="0.01"
                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                            <span class="error-msg text-red-500 text-xs mt-1 hidden"></span> </div>
                        <div> <label for="discount" class="block text-sm font-medium text-gray-700">Discount (%)</label>
                            <input type="number" id="discount" name="discount"
                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                            <span class="error-msg text-red-500 text-xs mt-1 hidden"></span> </div>
                        <div class="md:col-span-2"> <label for="productDescription"
                                class="block text-sm font-medium text-gray-700">Description</label> <textarea
                                id="productDescription" name="productDescription" rows="4"
                                class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all"></textarea>
                            <span class="error-msg text-red-500 text-xs mt-1 hidden"></span> </div>
                    </div>
                    <hr class="my-6 border-gray-200"> <!-- Variants Section -->
                    <div class="mb-6"> <label class="block text-sm font-medium text-gray-700 mb-3">Variants</label>
                        <p class="text-sm text-gray-500 mb-4">Add variants for each size. Each variant can have multiple
                            colors and its own stock quantity.</p>
                        <div id="variantsContainer" class="space-y-4">
                            <!-- Variant rows will be added here dynamically --> </div> <button type="button"
                            id="addVariant"
                            class="mt-4 text-sm text-rose-600 font-medium hover:text-rose-700 transition-colors flex items-center gap-1">
                            <i class="fa-solid fa-plus"></i> Add Variant </button> <span id="variantsError"
                            class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                    </div> <!-- Variant Template (hidden) --> <template id="variantTemplate">
                        <div class="variant-row bg-gray-50 rounded-lg border border-gray-200 p-4 space-y-3">
                            <div class="flex items-center justify-between">
                                <h4 class="font-medium text-gray-900">Variant</h4> <button type="button"
                                    class="remove-variant text-red-400 hover:text-red-600 text-lg leading-none px-1"
                                    title="Remove variant">&times;</button>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_2fr] gap-4">
                                <div> <label class="block text-sm font-medium text-gray-700">Size <span
                                            class="text-red-500">*</span></label> <select
                                        name="variants[__INDEX__][size]"
                                        class="variant-size mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all"
                                        required>
                                        <option value="">Select Size</option>
                                        <option value="XS">XS</option>
                                        <option value="S">S</option>
                                        <option value="M">M</option>
                                        <option value="L">L</option>
                                        <option value="XL">XL</option>
                                        <option value="XXL">XXL</option>
                                        <option value="XXXL">XXXL</option>
                                    </select> </div>
                                <div> <label class="block text-sm font-medium text-gray-700">Stock <span
                                            class="text-red-500">*</span></label> <input type="number"
                                        name="variants[__INDEX__][stock]"
                                        class="variant-stock mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all"
                                        min="0" value="0" required /> </div>
                                <div> <label class="block text-sm font-medium text-gray-700">Colors <span
                                            class="text-red-500">*</span></label>
                                    <div class="variant-colors flex flex-wrap gap-2 mt-1 min-h-[42px]"></div>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 pt-2 border-t border-gray-200">                                     <button type="button"
                                    class="add-color add-color-btn" title="Add color"> <i class="fa-solid fa-plus"></i>
                                    </svg> </button> <span class="text-xs text-gray-400">Add color</span> </div>
                        </div>
                    </template>
                    <hr class="my-6 border-gray-200">
                    <div> <label class="block text-sm font-medium text-gray-700 mb-3">Images</label>
                        <div id="imagePreview" class="flex gap-3 flex-wrap mb-3"></div> <input type="file" id="images"
                            name="images" accept="image/*" multiple
                            class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-rose-50 file:text-rose-600 hover:file:bg-rose-100 transition-colors" />
                        <span class="error-msg text-red-500 text-xs mt-1 hidden"></span>
                    </div>
                    <div class="mt-8 flex justify-end gap-3"> <a href="/admin/productList"
                            class="rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-semibold text-gray-700 hover:border-gray-400 transition-colors">Cancel</a>
                        <button type="submit"
                            class="rounded-lg bg-gray-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">Create
                            Product</button> </div>
                </form>
            </div>
        </div><!-- Cropper Modal -->
        <div id="cropperModal" class="fixed inset-0 z-50 bg-black/70 flex items-center justify-center hidden">
            <div class="bg-white rounded-xl p-6 max-w-2xl w-full mx-4">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Crop Image</h3> <button type="button"
                        id="closeCropper"
                        class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
                </div>
                <div class="max-h-[60vh] overflow-hidden flex items-center justify-center bg-gray-100 rounded-lg"> <img
                        id="cropImage" src="" class="max-w-full" /> </div>
                <div class="mt-4 flex justify-end gap-3"> <button type="button" id="cancelCrop"
                        class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:border-gray-400 transition-colors">Cancel</button>
                    <button type="button" id="confirmCrop"
                        class="rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-800 transition-colors">Crop
                        & Upload</button> </div>
            </div>
        </div>
        <% blocks.scripts = [
            '<script src="/javascript/ntc.js"><\/script>',
            '<script src="/javascript/admin/createProduct.js"><\/script>',
        ].join('\n'); %>