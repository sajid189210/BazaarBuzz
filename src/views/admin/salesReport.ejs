<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — Sales Report</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-50 antialiased">
    <div class="flex min-h-screen"> <%- include('../partials/adminSideMenu') %>
            <div class="flex-1 ml-0 lg:ml-[250px] min-w-0 transition-margin duration-300">
                <header class="sticky top-0 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 sm:py-4 z-40">
                        <div class="flex items-center gap-3">
                            <button id="adminSidebarToggle"
                                class="lg:hidden inline-flex items-center justify-center w-9 h-9 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
                                type="button">
                                <i class="fa-solid fa-bars"></i>
                            </button>
                            <span class="text-lg font-bold text-gray-900 sm:hidden">Bazaar<span class="text-rose-500">Buzz</span></span>
                            <div class="hidden sm:flex items-center gap-2 text-sm text-gray-500 min-w-0"> <a href="/admin/dashboard"
                                class="hover:text-gray-700 shrink-0">Dashboard</a> <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i> <span class="text-gray-900 font-semibold">Sales Report</span> </div>
                    </div>
                </header>
                <main class="p-4 sm:p-6">
                    <div class="flex items-center justify-end mb-6"> <select id="filter"
                            class="rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 transition-all"
                            onchange="selectFilter()">
                            <option value="">Filter By</option>
                            <option value="day" <%=selectedDate==='day' ? 'selected' : '' %>>Day</option>
                            <option value="week" <%=selectedDate==='week' ? 'selected' : '' %>>Week</option>
                            <option value="month" <%=selectedDate==='month' ? 'selected' : '' %>>Month</option>
                            <option value="year" <%=selectedDate==='year' ? 'selected' : '' %>>Year</option>
                        </select> </div>
                    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
                        <div class="overflow-x-auto">
                            <table class="min-w-full text-sm">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">Order ID</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">User Email</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600 hidden md:table-cell">Total Products</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">Total Amount</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600 hidden md:table-cell">Coupon Discount</th>
                                        <th class="text-left px-4 py-3 font-semibold text-gray-600">Payment Status</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    <% if(orders && orders.length> 0) { %> <% orders.forEach(order=> { %> <tr
                                                class="hover:bg-gray-50">
                                                <td class="px-4 py-3 text-gray-900 font-medium font-mono text-xs uppercase">
                                                    <%= String(order._id).slice(-8) %>
                                                </td>
                                                <td class="px-4 py-3 text-gray-600">
                                                    <%= order.user?.email || '-' %>
                                                </td>
                                                <td class="px-4 py-3 text-gray-600 hidden md:table-cell">
                                                    <%= order.items?.length || 0 %>
                                                </td>
                                                <td class="px-4 py-3 text-gray-900 font-medium">₹<%=
                                                        order.totalAmount?.toLocaleString() || 0 %>
                                                </td>
                                                <td class="px-4 py-3 text-gray-600 hidden md:table-cell">
                                                    <%= order.couponDiscount ? '₹' +
                                                        order.couponDiscount.toLocaleString() : '-' %>
                                                </td>
                                                <td class="px-4 py-3"> <span
                                                        class="inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full <%= order.paymentStatus === 'Paid' ? 'bg-green-50 text-green-700' : 'bg-amber-50 text-amber-700' %>">
                                                        <%= order.paymentStatus %>
                                                    </span> </td>
                                                <td class="px-4 py-3"><a href="/admin/viewOrder/<%= order._id %>"
                                                        class="text-xs font-medium text-rose-500 hover:text-rose-600">View</a>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="7" class="px-4 py-8 text-center text-gray-400">No
                                                            orders found</td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="mt-6 flex flex-col sm:flex-row justify-end gap-3"> <a href="/admin/salesreport/pdf"
                            class="rounded-lg border border-gray-300 px-5 py-2.5 text-sm font-semibold text-gray-700 hover:border-gray-400 transition-colors text-center">Download
                            PDF</a> <a href="/admin/salesreport/excel"
                            class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors text-center">Download
                            Excel</a> </div>
                </main>
            </div>
    </div>
    <script>
        (function() {
            var toggle = document.getElementById('adminSidebarToggle');
            var sidebar = document.getElementById('adminSidebar');
            var overlay = document.getElementById('adminSidebarOverlay');
            var close = document.getElementById('adminSidebarClose');
            if (!toggle || !sidebar) return;
            function open() {
                sidebar.classList.remove('-translate-x-full');
                if (overlay) overlay.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }
            function closeSidebar() {
                sidebar.classList.add('-translate-x-full');
                if (overlay) overlay.classList.add('hidden');
                document.body.style.overflow = '';
            }
            toggle.addEventListener('click', open);
            if (close) close.addEventListener('click', closeSidebar);
            if (overlay) overlay.addEventListener('click', closeSidebar);
            window.addEventListener('resize', function() {
                if (window.innerWidth >= 1024) {
                    sidebar.classList.remove('-translate-x-full');
                    if (overlay) overlay.classList.add('hidden');
                    document.body.style.overflow = '';
                }
            });
        })();
    </script>
</body>

</html>