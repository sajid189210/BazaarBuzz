<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — Returns</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-50 antialiased">
    <div class="flex min-h-screen"> <%- include('../partials/adminSideMenu') %>
            <div class="flex-1 ml-0 lg:ml-[250px] min-w-0 transition-margin duration-300">
                <header class="sticky top-0 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 sm:py-4 z-40">
                        <div class="flex items-center gap-3">
                            <button id="adminSidebarToggle"
                                class="lg:hidden inline-flex items-center justify-center w-9 h-9 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition-colors"
                                type="button">
                                <i class="fa-solid fa-bars"></i>
                            </button>
                            <span class="text-lg font-bold text-gray-900 sm:hidden">Bazaar<span class="text-rose-500">Buzz</span></span>
                            <div class="hidden sm:flex items-center gap-2 text-sm text-gray-500 min-w-0"> <a href="/admin/dashboard"
                                class="hover:text-gray-700 shrink-0">Dashboard</a> <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i> <span class="text-gray-900 font-semibold">Returns</span> </div>
                    </div>
                </header>
                <main class="p-4 sm:p-6">
                    <div class="mb-6">
                        <h1 class="text-xl sm:text-2xl font-bold text-gray-900">Returns</h1>
                        <p class="text-sm text-gray-500 mt-1">Review and manage customer return requests</p>
                    </div>

                    <div class="flex flex-wrap items-center gap-2 mb-4">
                        <a href="?status=all"
                            class="px-3 sm:px-4 py-2 rounded-lg text-xs sm:text-sm font-medium transition-colors <%= statusFilter === 'all' ? 'bg-rose-500 text-white' : 'bg-white text-gray-600 border border-gray-300 hover:bg-gray-50' %>">All</a>
                        <a href="?status=requested"
                            class="px-3 sm:px-4 py-2 rounded-lg text-xs sm:text-sm font-medium transition-colors <%= statusFilter === 'requested' ? 'bg-rose-500 text-white' : 'bg-white text-gray-600 border border-gray-300 hover:bg-gray-50' %>">Pending</a>
                        <a href="?status=approved"
                            class="px-3 sm:px-4 py-2 rounded-lg text-xs sm:text-sm font-medium transition-colors <%= statusFilter === 'approved' ? 'bg-rose-500 text-white' : 'bg-white text-gray-600 border border-gray-300 hover:bg-gray-50' %>">Approved</a>
                        <a href="?status=rejected"
                            class="px-3 sm:px-4 py-2 rounded-lg text-xs sm:text-sm font-medium transition-colors <%= statusFilter === 'rejected' ? 'bg-rose-500 text-white' : 'bg-white text-gray-600 border border-gray-300 hover:bg-gray-50' %>">Rejected</a>
                    </div>

                    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
                        <div class="overflow-x-auto">
                            <table class="min-w-full text-sm">
                                <thead class="bg-gray-50/80">
                                    <tr>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">Order ID</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">Product</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider hidden md:table-cell">Customer</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">Status</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider hidden md:table-cell">Reason</th>
                                        <th class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider hidden lg:table-cell">Date</th>
                                        <th class="text-center px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-50">
                                    <% if(returns && returns.length > 0) { %>
                                        <% returns.forEach(r => { %>
                                            <tr class="hover:bg-gray-50/50 transition-colors">
                                                <td class="px-5 py-4 font-mono font-medium text-xs text-gray-700 uppercase">#<%= String(r.orderId).slice(-8) %></td>
                                                <td class="px-5 py-4">
                                                    <div class="flex items-center gap-3">
                                                        <div class="w-10 h-12 rounded-lg overflow-hidden bg-gray-200 shrink-0">
                                                            <img src="<%= r.productImage || '/images/placeholder.jpg' %>" alt="" class="w-full h-full object-cover" />
                                                        </div>
                                                        <div>
                                                            <p class="text-sm font-medium text-gray-900"><%= r.productName %></p>
                                                            <p class="text-xs text-gray-500">Qty: <%= r.quantity %> × ₹<%= (r.unitPrice || 0).toLocaleString('en-IN') %></p>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="px-5 py-4 hidden md:table-cell">
                                                    <p class="text-sm text-gray-900"><%= r.user?.username || '-' %></p>
                                                    <p class="text-xs text-gray-500"><%= r.user?.email || '' %></p>
                                                </td>
                                                <td class="px-5 py-4">
                                                    <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full
                                                        <%= r.returnStatus === 'requested' ? 'bg-amber-50 text-amber-700 border border-amber-200' :
                                                           r.returnStatus === 'approved' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' :
                                                           'bg-rose-50 text-rose-700 border border-rose-200' %>">
                                                        <span class="w-1.5 h-1.5 rounded-full
                                                            <%= r.returnStatus === 'requested' ? 'bg-amber-500' :
                                                               r.returnStatus === 'approved' ? 'bg-emerald-500' :
                                                               'bg-rose-500' %>"></span>
                                                        <%= r.returnStatus === 'requested' ? 'Pending' : r.returnStatus.charAt(0).toUpperCase() + r.returnStatus.slice(1) %>
                                                    </span>
                                                </td>
                                                <td class="px-5 py-4 hidden md:table-cell">
                                                    <p class="text-sm text-gray-600 max-w-[200px] truncate" title="<%= r.reason %>"><%= r.reason || 'N/A' %></p>
                                                </td>
                                                <td class="px-5 py-4 text-gray-500 text-sm hidden lg:table-cell">
                                                    <%= new Date(r.requestedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                                </td>
                                                <td class="px-5 py-4">
                                                    <div class="flex items-center justify-center gap-2">
                                                        <a href="/admin/order/view?orderId=<%= r.orderId %>"
                                                            class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg bg-gray-50 text-gray-700 border border-gray-200 hover:bg-gray-100 transition-colors"
                                                            title="View Order">
                                                            <i class="fa-solid fa-eye"></i>
                                                        </a>
                                                        <% if(r.returnStatus === 'requested') { %>
                                                            <button onclick="approveReturn('<%= r.orderId %>','<%= r.itemId %>')"
                                                                class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg bg-emerald-50 text-emerald-700 border border-emerald-200 hover:bg-emerald-100 transition-colors">
                                                                <i class="fa-solid fa-check"></i>
                                                                Approve
                                                            </button>
                                                            <button onclick="rejectReturn('<%= r.orderId %>','<%= r.itemId %>')"
                                                                class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg bg-rose-50 text-rose-700 border border-rose-200 hover:bg-rose-100 transition-colors">
                                                                <i class="fa-solid fa-xmark"></i>
                                                                Reject
                                                            </button>
                                                        <% } %>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="px-5 py-16 text-center">
                                                <div class="flex flex-col items-center gap-3">
                                                    <i class="fa-regular fa-circle-check text-4xl text-gray-300"></i>
                                                    <span class="text-gray-400 text-sm font-medium">No return requests found</span>
                                                </div>
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                        <nav class="mt-8 flex items-center justify-center gap-2" aria-label="Pagination">
                            <a href="<%= currentPage > 1 ? '?page=' + (currentPage - 1) + (statusFilter !== 'all' ? '&status=' + statusFilter : '') : '#' %>"
                                class="min-h-[44px] px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors <%= currentPage === 1 ? 'opacity-50 pointer-events-none' : '' %>"
                                <%= currentPage === 1 ? 'aria-disabled="true"' : '' %>>
                                <i class="fa-solid fa-chevron-left"></i>
                                <span class="hidden sm:inline ml-1">Previous</span>
                            </a>
                            <div class="flex items-center gap-1">
                                <% var startPage = Math.max(1, currentPage - 2); var endPage = Math.min(totalPages, currentPage + 2); if (endPage - startPage < 4) { if (startPage === 1) { endPage = Math.min(totalPages, startPage + 4); } else if (endPage === totalPages) { startPage = Math.max(1, endPage - 4); } } %>
                                <% for (var i = startPage; i <= endPage; i++) { %>
                                    <a href="?page=<%= i %><%= statusFilter !== 'all' ? '&status=' + statusFilter : '' %>"
                                        class="min-w-[44px] h-11 flex items-center justify-center rounded-lg text-sm font-medium transition-colors <%= i === currentPage ? 'bg-rose-500 text-white' : 'text-gray-700 hover:bg-gray-100' %>"
                                        <%= i === currentPage ? 'aria-current="page"' : '' %>><%= i %></a>
                                <% } %>
                            </div>
                            <a href="<%= currentPage < totalPages ? '?page=' + (currentPage + 1) + (statusFilter !== 'all' ? '&status=' + statusFilter : '') : '#' %>"
                                class="min-h-[44px] px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors <%= currentPage === totalPages ? 'opacity-50 pointer-events-none' : '' %>"
                                <%= currentPage === totalPages ? 'aria-disabled="true"' : '' %>>
                                <span class="hidden sm:inline mr-1">Next</span>
                                <i class="fa-solid fa-chevron-right"></i>
                            </a>
                        </nav>
                        <div class="mt-4 text-center text-sm text-gray-500">
                            Page <%= currentPage %> of <%= totalPages %>
                        </div>
                    <% } %>
                </main>
            </div>
    </div>
    <script>
        (function() {
            var toggle = document.getElementById('adminSidebarToggle');
            var sidebar = document.getElementById('adminSidebar');
            var overlay = document.getElementById('adminSidebarOverlay');
            var close = document.getElementById('adminSidebarClose');
            if (!toggle || !sidebar) return;
            function open() { sidebar.classList.remove('-translate-x-full'); if (overlay) overlay.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
            function closeSidebar() { sidebar.classList.add('-translate-x-full'); if (overlay) overlay.classList.add('hidden'); document.body.style.overflow = ''; }
            toggle.addEventListener('click', open);
            if (close) close.addEventListener('click', closeSidebar);
            if (overlay) overlay.addEventListener('click', closeSidebar);
            window.addEventListener('resize', function() { if (window.innerWidth >= 1024) { sidebar.classList.remove('-translate-x-full'); if (overlay) overlay.classList.add('hidden'); document.body.style.overflow = ''; } });
        })();
    </script>
    <script src="/javascript/admin/adminReturns.js"></script>
</body>

</html>
