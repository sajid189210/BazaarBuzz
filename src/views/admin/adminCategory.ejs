<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — Categories</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-50 antialiased">
    <div class="flex min-h-screen"> <%- include('../partials/adminSideMenu') %>
            <div class="flex-1 ml-[250px]">
                <header class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 z-40">
                    <div class="flex items-center gap-2 text-sm text-gray-500"> <a href="/admin/dashboard"
                            class="hover:text-gray-700">Dashboard</a> <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i> <span class="text-gray-900 font-semibold">Categories</span> </div>
                </header>
                <main class="p-6">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <i class="fa-solid fa-box text-gray-400"></i>
                            <h1 class="text-2xl font-bold text-gray-900">Categories</h1>
                            <p class="text-sm text-gray-500 mt-1">Manage product categories and brands</p>
                        </div> <button onclick="openCategoryModal()"
                            class="rounded-lg bg-gray-900 hover:bg-gray-800 px-5 py-2.5 text-sm font-semibold text-white transition-colors flex items-center gap-2">
                            <i class="fa-solid fa-plus"></i> Add Category </button>
                    </div>
                    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
                        <div class="overflow-x-auto">
                            <table class="min-w-full text-sm">
                                <thead>
                                    <tr class="border-b border-gray-100 bg-gray-50/80">
                                        <th
                                            class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">
                                            #</th>
                                        <th
                                            class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">
                                            Category</th>
                                        <th
                                            class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">
                                            Brands</th>
                                        <th
                                            class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">
                                            Created</th>
                                        <th
                                            class="text-left px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">
                                            Status</th>
                                        <th
                                            class="text-right px-5 py-3.5 font-semibold text-gray-500 text-xs uppercase tracking-wider">
                                            Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-50">
                                    <% if(categories && categories.length> 0) { %> <% categories.forEach((cat, index)=>
                                            { %> <tr class="hover:bg-gray-50/50 transition-colors">
                                                <td class="px-5 py-4 text-gray-400 text-xs font-medium">
                                                    <%= index + 1 %>
                                                </td>
                                                <td class="px-5 py-4"> <span class="text-gray-900 font-medium">
                                                        <%= cat.title %>
                                                    </span> </td>
                                                <td class="px-5 py-4">
                                                    <% if(cat.brands && cat.brands.length> 0) { %>
                                                        <div class="flex flex-wrap gap-1.5 items-center">
                                                            <% cat.brands.slice(0, 3).forEach(function(b) { %> <span
                                                                    class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 border border-indigo-100">
                                                                    <%= b %>
                                                                </span>
                                                                <% }); %>
                                                                    <% if(cat.brands.length> 3) { %>
                                                                        <button type="button"
                                                                            onclick="var p=this.parentElement.nextElementSibling; p.classList.toggle('hidden'); this.textContent = p.classList.contains('hidden') ? '+' + this.dataset.count + ' more' : 'less'; event.stopPropagation();"
                                                                            class="brand-toggle text-xs font-medium text-indigo-600 hover:underline shrink-0"
                                                                            data-count="<%= cat.brands.length - 3 %>">+
                                                                            <%= cat.brands.length - 3 %>
                                                                                more
                                                                        </button>
                                                        </div>
                                                        <div class="hidden mt-2 max-h-32 overflow-y-auto brand-popover">
                                                            <div class="flex flex-wrap gap-1.5">
                                                                <% cat.brands.slice(3).forEach(function(b) { %>
                                                                    <span
                                                                        class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 border border-indigo-100">
                                                                        <%= b %>
                                                                    </span>
                                                                    <% }); %>
                                                            </div>
                                                        </div>
                                                        <% } else { %>
                        </div>
                        <% } %>
                            <% } else { %> <span class="text-gray-400">—</span>
                                <% } %>
                                    </td>
                                    <td class="px-5 py-4 text-gray-500 text-sm">
                                        <% const d=new Date(cat.createdAt); %>
                                            <%= !isNaN(d) ? d.toLocaleDateString('en-IN', { day: 'numeric' ,
                                                month: 'short' , year: 'numeric' }) : '—' %>
                                    </td>
                                    <td class="px-5 py-4"> <span
                                            class="inline-flex items-center gap-1.5 text-xs font-semibold px-2.5 py-1 rounded-full <%= cat.isActive ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-rose-50 text-rose-700 border border-rose-200' %>">
                                            <span
                                                class="w-1.5 h-1.5 rounded-full <%= cat.isActive ? 'bg-emerald-500' : 'bg-rose-500' %>"></span>
                                            <%= cat.isActive ? 'Active' : 'Inactive' %>
                                        </span> </td>
                                    <td class="px-5 py-4 text-right">
                                        <div class="flex items-center justify-end gap-1.5"> <button
                                                onclick="editCategory('<%= cat._id %>')"
                                                data-id="<%= cat._id %>"
                                                data-title="<%= cat.title %>"
                                                data-brands="<%= cat.brands ? cat.brands.join(', ') : '' %>"
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5
                                                text-xs font-medium text-gray-600 hover:text-gray-900
                                                hover:bg-gray-100 rounded-lg transition-colors"> <i class="fa-solid fa-pen-to-square"></i> Edit </button> <button
                                                onclick="toggleCategory('<%= cat._id %>')"
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg transition-colors <%= cat.isActive ? 'text-rose-600 hover:text-rose-700 hover:bg-rose-50' : 'text-emerald-600 hover:text-emerald-700 hover:bg-emerald-50' %>">
                                                <i class="fa-solid <%= cat.isActive ? 'fa-ban' : 'fa-check-circle' %>"></i>
                                                <%= cat.isActive ? 'Block' : 'Unblock' %>
                                            </button> <button onclick="deleteCategory('<%= cat._id %>')"
                                                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-red-500 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors">
                                                <i class="fa-solid fa-trash"></i> Delete </button> </div>
                                    </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="6" class="px-5 py-12 text-center">
                                                    <div class="flex flex-col items-center gap-2"> <i class="fa-regular fa-folder-open text-4xl text-gray-300"></i> <span class="text-gray-400 text-sm">No categories
                                                            found</span> <button onclick="openCategoryModal()"
                                                            class="text-sm text-rose-500 hover:text-rose-600 font-medium mt-1">Add
                                                            your first category</button> </div>
                                                </td>
                                            </tr>
                                            <% } %>
                                                </tbody>
                                                </table>
                    </div>
            </div>
            <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
                <nav class="mt-8 flex items-center justify-center gap-2" aria-label="Pagination">
                    <a href="<%= currentPage > 1 ? '?page=' + (currentPage - 1) : '#' %>"
                        class="px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors <%= currentPage === 1 ? 'opacity-50 pointer-events-none' : '' %>"
                        <%=currentPage===1 ? 'aria-disabled="true"' : '' %>>
                        <i class="fa-solid fa-chevron-left"></i>
                        <span class="hidden sm:inline ml-1">Previous</span>
                    </a>
                    <div class="flex items-center gap-1">
                        <% var startPage=Math.max(1, currentPage - 2); var endPage=Math.min(totalPages, currentPage +
                            2); if (endPage - startPage < 4) { if (startPage===1) { endPage=Math.min(totalPages,
                            startPage + 4); } else if (endPage===totalPages) { startPage=Math.max(1, endPage - 4); } }
                            %>
                            <% for (var i=startPage; i <=endPage; i++) { %>
                                <a href="?page=<%= i %>"
                                    class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-medium transition-colors <%= i === currentPage ? 'bg-rose-500 text-white' : 'text-gray-700 hover:bg-gray-100' %>"
                                    <%=i===currentPage ? 'aria-current="page"' : '' %>><%= i %></a>
                                <% } %>
                    </div>
                    <a href="<%= currentPage < totalPages ? '?page=' + (currentPage + 1) : '#' %>"
                        class="px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors <%= currentPage === totalPages ? 'opacity-50 pointer-events-none' : '' %>"
                        <%=currentPage===totalPages ? 'aria-disabled="true"' : '' %>>
                        <span class="hidden sm:inline mr-1">Next</span>
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </nav>
                <div class="mt-4 text-center text-sm text-gray-500">
                    Page <%= currentPage %> of <%= totalPages %>
                </div>
                <% } %>
                    </main>
    </div>
    </div> <!-- Category Modal -->
    <div id="categoryModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeCategoryModal()"></div>
        <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 p-8"> <button type="button"
                onclick="closeCategoryModal()"
                class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors"> <i class="fa-solid fa-xmark text-gray-400 hover:text-gray-600 text-xl"></i> </button>
            <h2 id="categoryModalTitle" class="text-xl font-bold text-gray-900 mb-6">Add Category</h2>
            <form id="categoryForm" class="space-y-4"> <input type="hidden" name="categoryId" id="categoryId">
                <div> <label for="categoryTitle" class="block text-sm font-medium text-gray-700">Category Name</label>
                    <input type="text" id="categoryTitle" name="title" required
                        class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                </div>
                <div> <label class="block text-sm font-medium text-gray-700">Brand Names</label>
                    <div class="flex gap-2 mt-1"> <input type="text" id="brandInput" placeholder="Type a brand and add"
                            onkeydown="if(event.key==='Enter'){event.preventDefault();addBrand();}"
                            class="flex-1 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                        <button type="button" onclick="addBrand()"
                            class="rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 shrink-0 transition-colors">Add</button>
                    </div>
                    <div id="brandList" class="flex flex-wrap gap-1.5 mt-3 min-h-[28px]">
                    </div>
                </div> <button type="submit"
                    class="w-full rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">Save</button>
            </form>
        </div>
    </div>
    <script src="/javascript/admin/adminCategory.js"></script>
    <script>
        document.addEventListener('click', function (e) {
            if (!e.target.closest('.brand-popover') && !e.target.closest('.brand-toggle')) {
                document.querySelectorAll('.brand-popover').forEach(function (p) {
                    p.classList.add('hidden');
                    var toggle = p.previousElementSibling.querySelector('.brand-toggle');
                    if (toggle) toggle.textContent = '+' + toggle.dataset.count + ' more';
                });
            }
        });
    </script>
</body>

</html>