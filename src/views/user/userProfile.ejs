<% blocks.head = `    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>` %><div class="mx-auto max-w-[800px] px-4 sm:px-6 lg:px-8 pt-6 pb-16">    <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-8">        <a href="/" class="hover:text-[var(--accent)] transition-colors btn-press">Home</a>        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><polyline points="9 18 15 12 9 6"/></svg>        <span class="text-gray-800 font-medium">My Profile</span>    </nav>    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-8">My Profile</h1>    <% if(userDetails) { %>    <div class="rounded-xl border border-gray-200 bg-white p-8">        <div class="flex items-center gap-4 mb-8">            <div class="w-16 h-16 rounded-full bg-gray-900 text-white flex items-center justify-center text-xl font-bold">                <%= (userDetails.username || 'U').charAt(0).toUpperCase() %>            </div>            <div>                <h2 class="text-lg font-semibold text-gray-900"><%= userDetails.username || 'User' %></h2>                <p class="text-sm text-gray-500"><%= userDetails.email || '' %></p>            </div>        </div>        <form id="profileForm" class="space-y-5">            <div>                <label for="username" class="block text-sm font-medium text-gray-700">Username</label>                <input type="text" name="username" id="username" value="<%= userDetails.username || '' %>"                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />                <div id="usernameError" class="text-xs text-red-500 mt-1 hidden"></div>            </div>            <div>                <label for="email" class="block text-sm font-medium text-gray-700">Email</label>                <input type="email" name="email" id="email" value="<%= userDetails.email || '' %>"                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />                <div id="emailError" class="text-xs text-red-500 mt-1 hidden"></div>            </div>            <div>                <label for="phone" class="block text-sm font-medium text-gray-700">Phone</label>                <input type="text" name="phone" id="phone" value="<%= userDetails.phone || '' %>"                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />                <div id="phoneError" class="text-xs text-red-500 mt-1 hidden"></div>            </div>            <button type="submit"                class="rounded-lg bg-gray-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors btn-press">Save Changes</button>        </form>        <hr class="my-8 border-gray-100">        <!-- Change Password -->        <h3 class="text-base font-semibold text-gray-900 mb-4">Change Password</h3>        <form id="passwordForm" class="space-y-5">            <div>                <label for="currentPassword" class="block text-sm font-medium text-gray-700">Current Password</label>                <input type="password" name="currentPassword" id="currentPassword"                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />            </div>            <div>                <label for="newPassword" class="block text-sm font-medium text-gray-700">New Password</label>                <input type="password" name="newPassword" id="newPassword"                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />            </div>            <button type="submit"                class="rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-semibold text-gray-700 hover:border-gray-400 transition-colors btn-press">Update Password</button>        </form>    </div>    <% } %></div><% blocks.scripts = `    <script src="/javascript/user/userProfile.js"></script>` %>