<% blocks.head=` <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>` %><div
        class="mx-auto max-w-[1000px] px-3 xs:px-4 sm:px-6 lg:px-8 pt-4 sm:pt-6 pb-16">
        <nav class="hidden lg:flex items-center gap-2 text-sm lg:text-base text-gray-500 mb-6 lg:mb-8"> <a href="/"
                class="hover:text-[var(--accent)] transition-colors btn-press">Home</a> <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i> <span class="text-gray-800 font-medium">My Profile</span> </nav>
        <h1 class="text-xl xs:text-2xl font-bold text-gray-900 mb-6">My Profile</h1>
        <% if(userDetails) { %>
            <div class="rounded-xl border border-gray-200 bg-white p-5 xs:p-6 sm:p-8">
                <div class="flex items-center gap-4 mb-8">
                    <div
                        class="w-14 xs:w-16 h-14 xs:h-16 rounded-full bg-gray-900 text-white flex items-center justify-center text-lg xs:text-xl font-bold">
                        <%= (userDetails.username || 'U' ).charAt(0).toUpperCase() %>
                    </div>
                    <div>
                        <h2 class="text-base xs:text-lg font-semibold text-gray-900">
                            <%= userDetails.username || 'User' %>
                        </h2>
                        <p class="text-sm text-gray-500">
                            <%= userDetails.email || '' %>
                        </p>
                    </div>
                </div>
                <form id="profileForm" class="space-y-5">
                    <div> <label for="username" class="block text-sm font-medium text-gray-700">Username</label> <input
                            type="text" name="username" id="username" value="<%= userDetails.username || '' %>"
                            class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                        <div id="usernameError" class="text-xs text-red-500 mt-1 hidden"></div>
                    </div>
                    <div> <label for="email" class="block text-sm font-medium text-gray-700">Email</label> <input
                            type="email" name="email" id="email" value="<%= userDetails.email || '' %>"
                            class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                        <div id="emailError" class="text-xs text-red-500 mt-1 hidden"></div>
                    </div>
                    <div> <label for="phone" class="block text-sm font-medium text-gray-700">Phone</label> <input
                            type="text" name="phone" id="phone" value="<%= userDetails.phone || '' %>" inputmode="numeric"
                            class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                        <div id="phoneError" class="text-xs text-red-500 mt-1 hidden"></div>
                    </div> <button type="submit"
                        class="w-full sm:w-auto rounded-lg bg-gray-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors btn-press">Save
                        Changes</button>
                </form>
                <hr class="my-8 border-gray-100">
                <h3 class="text-sm xs:text-base font-semibold text-gray-900 mb-4">Change Password</h3>
                <% if (userDetails.googleId) { %>
                    <p class="text-sm text-gray-500 mb-4">You signed up with Google. Password management is not available.</p>
                <% } else { %>
                <form id="passwordForm" class="space-y-5">
                    <div> <label for="currentPassword" class="block text-sm font-medium text-gray-700">Current
                            Password</label> <input type="password" name="currentPassword" id="currentPassword"
                            class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                    </div>
                    <div> <label for="newPassword" class="block text-sm font-medium text-gray-700">New Password</label>
                        <input type="password" name="newPassword" id="newPassword"
                            class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                    </div> <button type="submit"
                        class="w-full sm:w-auto rounded-lg border border-gray-300 px-6 py-2.5 text-sm font-semibold text-gray-700 hover:border-gray-400 transition-colors btn-press">Update
                        Password</button>
                </form>
                <% } %>
            </div>
            <% } %>
    </div>
    <% blocks.scripts=` <script src="/javascript/user/userProfile.js">
        </script>` %>