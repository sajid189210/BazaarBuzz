<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile</title>
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dark-theme.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
    <div class="relative font-[poppins]">
        <%- include('../partials/userHeader') %>
        <div class="absolute top-[60px] w-full min-h-screen bg-[#F5F6FA]">
            <div class="max-w-2xl mx-auto px-4 py-10">
                <div class="bg-white rounded-2xl shadow-sm p-8">
                    <div class="flex flex-col items-center mb-8">
                        <div class="relative">
                            <img src="/uploads/img_3.jpg" alt="" class="h-16 w-16 rounded-full object-cover border-4 border-gray-100">
                        </div>
                        <h2 class="text-lg font-bold text-gray-800 mt-3"><%= userDetails.username%></h2>
                        <p class="text-sm text-gray-400"><%= userDetails.email%></p>
                    </div>

                    <form class="space-y-4">
                        <div>
                            <label class="text-sm text-gray-500 block mb-1">Username</label>
                            <input type="text" value="<%= userDetails.username%>"
                                class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-gray-700 outline-none focus:border-pink-400 focus:bg-white transition-all">
                        </div>
                        <div>
                            <label class="text-sm text-gray-500 block mb-1">Email</label>
                            <input type="email" value="<%= userDetails.email%>"
                                class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-gray-500 outline-none cursor-not-allowed">
                        </div>
                        <div>
                            <label class="text-sm text-gray-500 block mb-1">Password</label>
                            <div class="relative">
                                <input type="password" value="********"
                                    class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm text-gray-500 outline-none cursor-not-allowed">
                                <a href="/forgot-password" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-medium text-pink-500 hover:text-pink-600">Change</a>
                            </div>
                        </div>
                        <div class="flex gap-3 pt-2">
                            <button type="submit" class="px-6 py-2.5 bg-pink-500 hover:bg-pink-600 text-white text-sm font-semibold rounded-xl transition-colors">Save</button>
                            <a href="/" class="px-6 py-2.5 border border-gray-300 text-gray-600 text-sm font-semibold rounded-xl hover:bg-gray-50 transition-colors">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>