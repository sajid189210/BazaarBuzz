<% layout('layout') -%>
<% blocks.head = `
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
` %>

<div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 pt-6 pb-16">
    <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-rose-500 transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-gray-800 font-medium">Wishlist</span>
    </nav>

    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-8">Wishlist</h1>

    <% if(wishlist && wishlist.items && wishlist.items.length > 0) { %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6">
        <% wishlist.items.forEach(item => { const product = item.product; %>
        <div class="group">
            <a href="/user/viewProduct?productId=<%= product._id %>" class="block">
                <div class="relative overflow-hidden rounded-xl bg-gray-50 aspect-[3/4]">
                    <img src="<%= product.images[0] %>" alt="<%= product.productName %>"
                        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out" />
                    <% if(product.discount) { %>
                    <div class="absolute top-3 left-3 bg-rose-500 text-white text-[10px] font-semibold px-2.5 py-1 rounded-full">-<%= product.discount %>% off</div>
                    <% } %>
                    <button onclick="removeFromWishlist('<%= product._id %>')"
                        class="absolute top-3 right-3 w-8 h-8 rounded-full bg-white/80 backdrop-blur-sm flex items-center justify-center text-rose-500 hover:bg-white transition-colors shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    </button>
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300"></div>
                </div>
                <div class="mt-3 space-y-1">
                    <p class="text-[11px] text-gray-400 uppercase tracking-widest"><%= product.brand || 'BazaarBuzz' %></p>
                    <h3 class="text-sm font-medium text-gray-800 truncate"><%= product.productName %></h3>
                    <div class="flex items-center gap-2">
                        <% if(product.discount) { %>
                        <span class="text-sm font-semibold text-gray-900">₹<%= Math.round(product.productPrice - (product.productPrice * product.discount / 100)).toLocaleString() %></span>
                        <span class="text-xs text-gray-400 line-through">₹<%= product.productPrice.toLocaleString() %></span>
                        <% } else { %>
                        <span class="text-sm font-semibold text-gray-900">₹<%= product.productPrice.toLocaleString() %></span>
                        <% } %>
                    </div>
                </div>
            </a>
        </div>
        <% }) %>
    </div>
    <% } else { %>
    <div class="flex flex-col items-center justify-center py-20">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 mb-4"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <h3 class="text-lg font-semibold text-gray-500">Your wishlist is empty</h3>
        <a href="/user/productList" class="mt-4 text-sm font-medium text-rose-500 hover:text-rose-600 transition-colors">Discover Products</a>
    </div>
    <% } %>
</div>

<% blocks.scripts = `
    <script>
        async function removeFromWishlist(productId) {
            try {
                const res = await fetch('/user/removeList', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ productId }) });
                const data = await res.json();
                if (data.success) {
                    Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 }).fire({ icon: 'success', title: data.message });
                    setTimeout(() => location.reload(), 1500);
                }
            } catch (e) { console.log(e); }
        }
    </script>
` %>