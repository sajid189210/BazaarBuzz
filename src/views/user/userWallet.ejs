<% blocks.head=` <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>` %>
<div class="mx-auto max-w-[800px] px-4 sm:px-6 lg:px-8 pt-6 pb-16">
  <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-8">
    <a href="/" class="hover:text-[var(--accent)] transition-colors btn-press">Home</a>
    <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i>
    <span class="text-gray-800 font-medium">Wallet</span>
  </nav>

  <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-8">My Wallet</h1>

  <div class="rounded-xl bg-gradient-to-br from-gray-900 to-gray-800 p-8 text-white <%= (!wallet || wallet.balance <= 0) ? 'opacity-70' : '' %>">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-300 font-medium">Available Balance</p>
        <p class="text-4xl font-bold mt-2">₹<%= (wallet?.balance || 0).toLocaleString() %></p>
        <p class="text-xs text-gray-400 mt-2">Valid for use on all purchases</p>
      </div>
      <% if(wallet && wallet.balance > 0) { %>
        <div class="hidden sm:flex items-center gap-1.5 text-xs text-green-300 bg-white/10 rounded-full px-3 py-1.5">
          <i class="fa-solid fa-check text-green-300 text-xs"></i>
          Active
        </div>
      <% } else { %>
        <div class="hidden sm:flex items-center gap-1.5 text-xs text-gray-400 bg-white/10 rounded-full px-3 py-1.5">
          <i class="fa-solid fa-circle-exclamation text-gray-400 text-xs"></i>
          No funds
        </div>
      <% } %>
    </div>
  </div>

  <hr class="my-8 border-gray-200">

  <% if(transactions && transactions.length > 0) { %>
    <div>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-base font-semibold text-gray-900">Transaction History</h2>
        <p class="text-xs text-gray-400"><%= totalPages > 0 ? 'Page ' + currentPage + ' of ' + totalPages : '' %></p>
      </div>
      <div class="space-y-2">
        <% transactions.forEach(txn => { %>
          <div class="flex items-center justify-between gap-3 rounded-lg border border-gray-200 bg-white p-4 text-sm hover:border-gray-300 transition-colors min-w-0">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 <%= txn.type === 'credit' ? 'bg-green-50' : 'bg-red-50' %>">
                <% if(txn.type === 'credit') { %>
                  <i class="fa-solid fa-arrow-up text-green-600"></i>
                <% } else { %>
                  <i class="fa-solid fa-arrow-down text-red-500"></i>
                <% } %>
              </div>
              <div class="min-w-0">
                <p class="font-medium text-gray-900 truncate">
                  <% if(txn.type === 'credit') { %>
                    Refund
                  <% } else { %>
                    Payment
                  <% } %>
                </p>
                <p class="text-xs text-gray-400 mt-0.5 font-mono">Txn #<%= String(txn._id).slice(-8) %></p>
                <p class="text-xs text-gray-400 mt-0.5"><%= new Date(txn.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
              </div>
            </div>
            <div class="text-right shrink-0">
              <p class="font-semibold <%= txn.type === 'credit' ? 'text-green-600' : 'text-red-500' %>">
                <%= txn.type === 'credit' ? '+' : '-' %>₹<%= txn.amount.toLocaleString() %>
              </p>
              <p class="text-xs text-gray-400 mt-0.5">₹<%= (txn.balanceBefore || 0).toLocaleString() %> → ₹<%= (txn.balanceAfter || 0).toLocaleString() %></p>
            </div>
          </div>
        <% }) %>
      </div>

      <% if(totalPages > 1) { %>
        <div class="flex items-center justify-center gap-3 mt-6">
          <% if(currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %>&limit=<%= limit %>" class="min-h-[44px] inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors btn-press">
              <i class="fa-solid fa-chevron-left text-xs"></i>
              Previous
            </a>
          <% } %>
          <span class="text-sm text-gray-400">Page <%= currentPage %> of <%= totalPages %></span>
          <% if(currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %>&limit=<%= limit %>" class="min-h-[44px] inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition-colors btn-press">
              Next
              <i class="fa-solid fa-chevron-right text-xs"></i>
            </a>
          <% } %>
        </div>
      <% } %>
    </div>
  <% } else { %>
    <div class="flex flex-col items-center justify-center py-20">
      <i class="fa-regular fa-credit-card text-5xl text-gray-300 mb-4"></i>
      <h3 class="text-lg font-semibold text-gray-500">No transactions yet</h3>
      <p class="text-sm text-gray-400 mt-1">Your transaction history will appear here</p>
    </div>
  <% } %>
</div>