<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product ? product.productName : 'Product' %> — BazaarBuzz</title>
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-white min-h-screen antialiased">
    <%- include('../partials/userHeader') %>
    <%- include('../partials/userNav') %>

    <% if(product) { %>
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 pt-6 pb-16">
        <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-8">
            <a href="/" class="hover:text-rose-500 transition-colors">Home</a>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><polyline points="9 18 15 12 9 6"/></svg>
            <a href="/user/productList" class="hover:text-rose-500 transition-colors">Products</a>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="text-gray-800 font-medium"><%= product.productName %></span>
        </nav>

        <div class="lg:flex lg:gap-12">
            <div class="lg:w-1/2">
                <div class="sticky top-24">
                    <div class="relative overflow-hidden rounded-2xl bg-gray-50">
                        <img id="mainImage" src="<%= product.images && product.images.length > 0 ? product.images[0] : '/images/placeholder.jpg' %>" alt="<%= product.productName %>" class="w-full h-auto object-cover aspect-[4/5]" />
                        <% if(product.discount) { %>
                        <div class="absolute top-4 left-4 bg-rose-500 text-white text-xs font-semibold px-3 py-1.5 rounded-full">-<%= product.discount %>% off</div>
                        <% } %>
                    </div>
                    <% if(product.images && product.images.length > 1) { %>
                    <div class="flex gap-3 mt-4">
                        <% product.images.forEach((img, index) => { %>
                        <button onclick="document.getElementById('mainImage').src='<%= img %>'; document.querySelectorAll('.thumb').forEach(t=>t.classList.remove('ring-2','ring-rose-500')); this.classList.add('ring-2','ring-rose-500')" class="thumb w-20 h-20 rounded-xl overflow-hidden bg-gray-50 border border-gray-200 <%= index === 0 ? 'ring-2 ring-rose-500' : '' %>">
                            <img src="<%= img %>" alt="" class="w-full h-full object-cover" />
                        </button>
                        <% }) %>
                    </div>
                    <% } %>
                </div>
            </div>

            <div class="mt-8 lg:mt-0 lg:w-1/2">
                <p class="text-xs text-gray-400 uppercase tracking-widest"><%= product.brand || 'BazaarBuzz' %></p>
                <h1 class="mt-2 text-2xl lg:text-3xl font-bold text-gray-900"><%= product.productName %></h1>

                <div class="flex items-center gap-4 mt-4">
                    <% if(product.discount) { %>
                    <span class="text-2xl font-bold text-gray-900">₹<%= Math.round(product.productPrice - (product.productPrice * product.discount / 100)).toLocaleString() %></span>
                    <span class="text-lg text-gray-400 line-through">₹<%= product.productPrice.toLocaleString() %></span>
                    <span class="text-sm font-semibold text-rose-500 bg-rose-50 px-2.5 py-0.5 rounded-full">Save <%= product.discount %>%</span>
                    <% } else { %>
                    <span class="text-2xl font-bold text-gray-900">₹<%= product.productPrice.toLocaleString() %></span>
                    <% } %>
                </div>

                <p class="text-sm text-gray-600 leading-relaxed whitespace-pre-line"><%= product.description %></p>

                <form class="mt-8 space-y-5" id="cart-form">
                    <input type="hidden" name="productId" value="<%= product._id %>">

                    <% if(product.variants && product.variants.length > 0) { %>
                    <div>
                        <label class="text-sm font-medium text-gray-900">Size</label>
                        <div class="flex flex-wrap gap-2 mt-2">
                            <% const uniqueSizes = [...new Set(product.variants.map(v => v.size).filter(Boolean))]; %>
                            <% uniqueSizes.forEach(s => { %>
                            <label class="relative cursor-pointer">
                                <input type="radio" name="size" value="<%= s %>" class="sr-only peer" <%= s === 'M' ? 'checked' : '' %> required>
                                <div class="px-4 py-2 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg peer-checked:border-gray-900 peer-checked:bg-gray-900 peer-checked:text-white hover:border-gray-400 transition-all"><%= s %></div>
                            </label>
                            <% }) %>
                        </div>
                    </div>
                    <% } %>

                    <% const allColors = [...new Set(product.variants.flatMap(v => v.colors || []).filter(Boolean))]; %>
                    <% if(allColors.length > 0) { %>
                    <div>
                        <label class="text-sm font-medium text-gray-900">Color</label>
                        <div class="flex flex-wrap gap-2 mt-2">
                            <% allColors.forEach((c, i) => { %>
                            <label class="relative cursor-pointer">
                                <input type="radio" name="color" value="<%= c %>" class="sr-only peer" <%= i === 0 ? 'checked' : '' %> required>
                                <div class="w-8 h-8 rounded-full border-2 border-gray-300 peer-checked:border-gray-900 peer-checked:ring-2 peer-checked:ring-gray-900/20 transition-all" style="background:<%= c %>"></div>
                            </label>
                            <% }) %>
                        </div>
                    </div>
                    <% } %>

                    <div>
                        <label class="text-sm font-medium text-gray-900">Quantity</label>
                        <div class="flex items-center gap-3 mt-2">
                            <button type="button" onclick="decrementQuantity()" class="w-9 h-9 rounded-lg border border-gray-300 flex items-center justify-center text-gray-600 hover:border-gray-400 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            </button>
                            <span id="quantityValue" class="w-10 text-center text-sm font-semibold text-gray-900">1</span>
                            <input type="hidden" name="quantity" id="quantity" value="1" />
                            <button type="button" onclick="incrementQuantity()" class="w-9 h-9 rounded-lg border border-gray-300 flex items-center justify-center text-gray-600 hover:border-gray-400 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            </button>
                        </div>
                    </div>

                    <div class="flex gap-3">
                        <button type="submit" id="addToCartBtn"
                            class="flex-1 rounded-lg bg-gray-900 px-6 py-3 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">Add to Cart</button>
                        <button type="button" onclick="addToWishList('<%= product._id %>')"
                            class="w-12 h-12 rounded-lg border border-gray-300 flex items-center justify-center text-gray-600 hover:border-rose-300 hover:text-rose-500 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        </button>
                    </div>

                    <div id="responseMessage" class="text-sm text-center"></div>
                </form>
            </div>
        </div>
    </div>
    <% } else { %>
    <div class="flex flex-col items-center justify-center py-24">
        <h2 class="text-xl font-semibold text-gray-500">Product not found</h2>
    </div>
    <% } %>

    <%- include('../partials/userFooter') %>

    <script src="/javascript/user/userProductView.js"></script>
    <script>
        function incrementQuantity() {
            const input = document.getElementById('quantity');
            const display = document.getElementById('quantityValue');
            let val = parseInt(input.value) || 1;
            if (val < 10) { val++; input.value = val; display.textContent = val; }
        }
        function decrementQuantity() {
            const input = document.getElementById('quantity');
            const display = document.getElementById('quantityValue');
            let val = parseInt(input.value) || 1;
            if (val > 1) { val--; input.value = val; display.textContent = val; }
        }
        async function addToWishList(productId) {
            if (!productId) return;
            try {
                const res = await fetch('/user/wishlist', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ productId }) });
                const data = await res.json();
                if (!data.session) { await Swal.fire({ title: 'Sign In!', text: data.message, icon: 'info' }); window.location.href = data.redirectUrl; return; }
                if (!data.success) { await Swal.fire({ title: 'Failed', text: data.message, icon: 'warning' }); if (data.redirectUrl) window.location.href = data.redirectUrl; return; }
                Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000 }).fire({ icon: 'success', title: data.message });
            } catch (e) { console.log(e); alert('Error'); }
        }
    </script>
</body>
</html>
