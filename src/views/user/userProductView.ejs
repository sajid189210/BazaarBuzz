<% if(!product) { %>    <div class="min-h-screen flex items-center justify-center px-4">        <div class="text-center">            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-gray-300 mb-4">                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>            </svg>            <h2 class="text-xl font-semibold text-gray-500">Product Not Found</h2>            <p class="text-gray-400 mt-2">The product you're looking for doesn't exist or has been removed.</p>            <a href="/user/getProductList/all" class="inline-block mt-6 text-rose-500 hover:text-rose-600 font-medium">Browse Products</a>        </div>    </div><% } else { %><!-- Page-specific styles --><% blocks.head = `    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>    <!-- Motion for micro-interactions -->    <script src="https://cdn.jsdelivr.net/npm/motion@latest/dist/motion.min.js"></script>    <link rel="stylesheet" href="/css/product-view.css">` %><!-- Page-specific scripts --><% blocks.scripts = `    <script src="/javascript/user/userProductView.js"></script>    <script>        // Pass server data to client        window.productData = {            images: ${JSON.stringify(product.images || [])},            variants: ${JSON.stringify(product.variants || [])},            sizeColorStock: ${sizeColorStock},            uniqueSizes: ${JSON.stringify(uniqueSizes || [])},            allColors: ${JSON.stringify(allColors || [])},            productId: '${product._id}',            offerDiscountedPrice: '${offerDiscountedPrice}',            productPrice: ${product.productPrice},            discount: ${product.discount || 0},            isInWishlist: ${isInWishlist ? 'true' : 'false'}        };                // Design tokens for client-side use        window.designTokens = ${designTokens || '{}'};                // Initialize on load        document.addEventListener('DOMContentLoaded', () => {            initProductPage();        });    </script>` %><main class="page-wrapper" style="padding-top: var(--spacing-xl); padding-bottom: var(--spacing-2xl);">    <!-- Breadcrumbs -->    <nav class="breadcrumbs" aria-label="Breadcrumb">        <a href="/">Home</a>        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>        <a href="/user/getProductList/all">Products</a>        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>        <span aria-current="page"><%= product.productName %></span>    </nav><!-- Social proof removed per brand guidelines -->    <div class="product-grid">        <!-- LEFT: Image Gallery -->        <div class="gallery-col">            <div class="gallery-main" id="mainImageContainer" onclick="openImageModal(0)" role="button" tabindex="0" aria-label="Zoom product image">                <img id="mainImage" src="<%= product.images && product.images.length > 0 ? product.images[0] : '/images/placeholder.jpg' %>" alt="<%= product.productName %>" loading="eager" />                <% if(product.discount) { %>                <div class="gallery-badge">-<%= product.discount %>% off</div>                <% } %>                <div class="zoom-hint">                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>                    Zoom                </div>            </div>            <!-- Thumbnail Strip -->            <% if(product.images && product.images.length > 1) { %>            <div class="mt-4" style="margin-top: var(--spacing-md);">                <div class="thumbnail-strip vertical" id="thumbnailStrip" role="listbox" aria-label="Product images">                    <% product.images.forEach((img, index) => { %>                    <button class="thumb-btn <%= index === 0 ? 'active' : '' %>"                             onclick="selectThumbnail(<%= index %>, this)"                             role="option"                             aria-selected="<%= index === 0 ? 'true' : 'false' %>"                            aria-label="View image <%= index + 1 %>"                            tabindex="0">                        <img src="<%= img %>" alt="" loading="lazy" />                    </button>                    <% }) %>                </div>            </div>            <% } %>        </div>        <!-- RIGHT: Buy Box -->        <div class="buy-box">            <div style="display: flex; flex-direction: column; gap: var(--spacing-lg);">                <!-- Brand & Title -->                <div>                    <p style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);"><%= product.brand || 'BazaarBuzz' %></p>                    <h1 style="margin-top: var(--spacing-xs); font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 800; line-height: 1.1; color: var(--text-primary);"><%= product.productName %></h1>                </div>                <!-- Price Block -->                <div class="price-block">                    <span class="price-current">₹<%= offerDiscountedPrice %></span>                    <% if(product.discount || offerDiscountValue) { %>                    <span class="price-original">₹<%= product.productPrice.toLocaleString() %></span>                    <span class="price-save">Save <%= Math.round(totalDiscount) %>%</span>                    <% } %>                </div>                <!-- Offer badge -->                <% if(offerDiscountValue) { %>                <div class="offer-badge">                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>                    <%= offerDiscountValue %>% brand offer applied                </div>                <% } %>                <!-- Trust Strip (compact) -->                <div class="trust-strip" role="list" aria-label="Trust signals">                    <div class="trust-item" role="listitem">                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>                        <span>Secure Payment<div class="trust-tooltip">100% encrypted checkout</div></span>                    </div>                    <div class="trust-item" role="listitem">                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>                        <span>Free Shipping<div class="trust-tooltip">On orders above ₹999</div></span>                    </div>                    <div class="trust-item" role="listitem">                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/><path d="M23 21v-8a1 1 0 0 0-1-1h-5"/></svg>                        <span>Easy Returns<div class="trust-tooltip">14 days, free pickup</div></span>                    </div>                    <div class="trust-item" role="listitem">                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>                        <span>COD Available<div class="trust-tooltip">Check at checkout</div></span>                    </div>                </div>                <!-- Variant Selection Form -->                <form class="space-y-6" id="cart-form" style="display: flex; flex-direction: column; gap: var(--spacing-lg);">                    <input type="hidden" name="productId" value="<%= product._id %>">                    <input type="hidden" name="size" id="selectedSize" value="">                    <input type="hidden" name="color" id="selectedColor" value="">                    <input type="hidden" name="quantity" id="quantity" value="1" />                    <!-- Size Selection -->                    <div>                        <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: var(--text-primary); margin-bottom: var(--spacing-sm);">Size <span style="font-weight: 400; color: var(--text-muted);">(Required)</span></label>                        <div class="size-chips" id="sizeChips" role="radiogroup" aria-label="Select size">                            <% if(sizeData && sizeData.length > 0) { %>                                <% sizeData.forEach((s, idx) => { %>                                    <button type="button"                                             class="size-chip <%= idx === 0 && !s.isOutOfStock ? 'selected' : '' %> <%= s.isLowStock ? 'low-stock' : '' %> <%= s.isOutOfStock ? 'out-of-stock' : '' %>"                                             data-size="<%= s.size %>"                                            data-stock="<%= s.stock %>"                                            onclick="selectSize(this, '<%= s.size %>', <%= s.stock %>)"                                            <%= s.isOutOfStock ? 'disabled' : '' %>                                            role="radio"                                            aria-checked="<%= idx === 0 && !s.isOutOfStock ? 'true' : 'false' %>"                                            tabindex="0">                                        <%= s.size %>                                        <% if(s.isLowStock && !s.isOutOfStock) { %>                                        <span class="stock-badge-inline">Low Stock</span>                                        <% } else if(s.isOutOfStock) { %>                                        <span class="stock-badge-inline">Out of Stock</span>                                        <% } %>                                    </button>                                <% }) %>                            <% } else { %>                                <span style="font-size: 0.875rem; color: var(--text-muted);">No sizes available</span>                            <% } %>                        </div>                    </div>                    <!-- Color Selection -->                    <div id="colorSection" class="<%= uniqueSizes && uniqueSizes.length > 0 ? '' : 'hidden' %>" style="<%= uniqueSizes && uniqueSizes.length > 0 ? '' : 'display: none;' %>">                        <label style="display: block; font-size: 0.8125rem; font-weight: 600; color: var(--text-primary); margin-bottom: var(--spacing-sm);">Color <span style="font-weight: 400; color: var(--text-muted);">(Required)</span></label>                        <div class="color-swatches" id="colorSwatches" role="radiogroup" aria-label="Select color">                            <!-- Populated dynamically via JS based on selected size -->                        </div>                    </div>                    <!-- Quantity + Stock + Delivery Row (combined) -->                    <div class="stock-delivery-row">                        <div style="display: flex; align-items: center; gap: var(--spacing-md); flex: 1; min-width: 0;">                            <span id="stockBadge" class="stock-badge in-stock">In Stock</span>                            <span id="stockText" class="stock-text"></span>                        </div>                        <div class="pincode-field">                            <label for="pincode">Delivery:</label>                            <input type="text" id="pincode" class="pincode-input" placeholder="Pincode" maxlength="6" pattern="[0-9]*" inputmode="numeric" aria-label="Enter pincode to check delivery" />                            <button type="button" class="pincode-btn" onclick="checkPincode()">Check</button>                        </div>                        <div id="pincodeResult" class="pincode-result" aria-live="polite"></div>                    </div>                    <!-- Quantity Selector (minimal) -->                    <div style="display: flex; align-items: center; gap: var(--spacing-md); flex-wrap: wrap;">                        <label style="font-size: 0.8125rem; font-weight: 600; color: var(--text-primary);">Qty</label>                        <div class="qty-selector">                            <button type="button" class="qty-btn" onclick="decrementQuantity()" aria-label="Decrease quantity">                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>                            </button>                            <span id="quantityValue" class="qty-value">1</span>                            <button type="button" class="qty-btn" onclick="incrementQuantity()" aria-label="Increase quantity">                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>                            </button>                            <span id="maxStockHint" class="qty-hint"></span>                        </div>                    </div>                    <!-- Action Buttons -->                    <div class="action-row">                        <button type="submit" id="addToCartBtn" class="btn-primary" disabled>                            Add to Cart                        </button>                        <button type="button" id="wishlistBtn" onclick="toggleWishList('<%= product._id %>')" class="btn-wishlist <%= isInWishlist ? 'filled' : '' %>" aria-label="<%= isInWishlist ? 'Remove from wishlist' : 'Add to wishlist' %>">                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>                        </button>                    </div>                    <div id="responseMessage" style="font-size: 0.8125rem; text-align: center; min-height: 1.25rem;"></div>                </form>                <!-- Product Meta -->                <div class="meta-list">                    <div class="meta-item"><span class="meta-label">Category:</span><span><%= product.category %></span></div>                    <div class="meta-item"><span class="meta-label">Gender:</span><span><%= product.gender %></span></div>                    <div class="meta-item"><span class="meta-label">Fabric:</span><span><%= product.fabric %></span></div>                </div>            </div>        </div>    </div>    <!-- DETAIL TABS (Below Fold) -->    <div style="margin-top: var(--spacing-2xl);">        <div class="tab-bar" role="tablist" aria-label="Product details">            <button class="tab-btn active" role="tab" aria-selected="true" aria-controls="tab-description" onclick="showTab('description')" tabindex="0">Description</button>            <button class="tab-btn" role="tab" aria-selected="false" aria-controls="tab-specs" onclick="showTab('specs')" tabindex="0">Specifications</button>            <button class="tab-btn" role="tab" aria-selected="false" aria-controls="tab-sizeguide" onclick="showTab('sizeguide')" tabindex="0">Size Guide</button>            <button class="tab-btn" role="tab" aria-selected="false" aria-controls="tab-reviews" onclick="showTab('reviews')" tabindex="0">Reviews</button>            <button class="tab-btn" role="tab" aria-selected="false" aria-controls="tab-shipping" onclick="showTab('shipping')" tabindex="0">Shipping & Returns</button>        </div>        <div style="max-width: 720px;">            <!-- Description Tab -->            <div id="tab-description" class="tab-panel active" role="tabpanel" aria-labelledby="tab-description">                <div style="font-size: 1rem; line-height: 1.8; color: var(--text-secondary); max-width: 65ch;">                    <p style="white-space: pre-line; margin: 0;"><%= product.description %></p>                </div>            </div>            <!-- Specifications Tab -->            <div id="tab-specs" class="tab-panel" role="tabpanel" aria-labelledby="tab-specs">                <div class="specs-table" role="table">                    <dl role="row"><dt role="rowheader">Brand</dt><dd role="cell"><%= product.brand %></dd></dl>                    <dl role="row"><dt role="rowheader">Category</dt><dd role="cell"><%= product.category %></dd></dl>                    <dl role="row"><dt role="rowheader">Gender</dt><dd role="cell"><%= product.gender %></dd></dl>                    <dl role="row"><dt role="rowheader">Fabric</dt><dd role="cell"><%= product.fabric %></dd></dl>                    <dl role="row"><dt role="rowheader">Available Sizes</dt><dd role="cell"><%= uniqueSizes?.join(', ') || 'N/A' %></dd></dl>                    <dl role="row"><dt role="rowheader">Available Colors</dt><dd role="cell"><%= allColors?.join(', ') || 'N/A' %></dd></dl>                    <% if(product.limitedEdition) { %>                    <dl role="row"><dt role="rowheader">Edition</dt><dd role="cell">Limited Edition</dd></dl>                    <% } %>                </div>            </div>            <!-- Size Guide Tab -->            <div id="tab-sizeguide" class="tab-panel" role="tabpanel" aria-labelledby="tab-sizeguide">                <div style="padding: var(--spacing-md) 0;">                    <p style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: var(--spacing-md);">Find your perfect fit. Measurements are in centimeters.</p>                    <button type="button" onclick="openSizeGuide()" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1rem; font-size: 0.8125rem; font-weight: 600; color: var(--accent); border: 1px solid var(--accent-border); background: var(--accent-light); border-radius: var(--radius-md); transition: all var(--motion-fast);" onmouseover="this.style.background='var(--accent)';this.style.color='white';" onmouseout="this.style.background='var(--accent-light)';this.style.color='var(--accent)';">                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>                        Open Size Guide                    </button>                </div>            </div>            <!-- Reviews Tab (Placeholder) -->            <div id="tab-reviews" class="tab-panel" role="tabpanel" aria-labelledby="tab-reviews">                <div style="padding: var(--spacing-2xl) 0; text-align: center;">                    <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin: 0 auto var(--spacing-md); color: var(--text-muted);"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>                    <h3 style="font-size: 1.125rem; font-weight: 700; color: var(--text-primary); margin-bottom: var(--spacing-xs);">Reviews Coming Soon</h3>                    <p style="font-size: 0.875rem; color: var(--text-muted);">Customer reviews will appear here once available.</p>                </div>            </div>            <!-- Shipping & Returns Tab -->            <div id="tab-shipping" class="tab-panel" role="tabpanel" aria-labelledby="tab-shipping">                <div style="display: flex; flex-direction: column; gap: var(--spacing-xl);">                    <div>                        <h4 style="font-size: 0.9375rem; font-weight: 700; color: var(--text-primary); margin-bottom: var(--spacing-md);">Shipping</h4>                        <ul style="font-size: 0.875rem; color: var(--text-secondary); line-height: 2; list-style: none; padding: 0;">                            <li style="display: flex; align-items: flex-start; gap: 0.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 0.125rem; color: var(--accent);"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>Free standard shipping on orders above ₹999</li>                            <li style="display: flex; align-items: flex-start; gap: 0.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 0.125rem; color: var(--accent);"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>Standard delivery: 5–7 business days</li>                            <li style="display: flex; align-items: flex-start; gap: 0.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 0.125rem; color: var(--accent);"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>Express delivery: 2–3 business days (additional charges)</li>                            <li style="display: flex; align-items: flex-start; gap: 0.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 0.125rem; color: var(--accent);"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>Cash on Delivery available for eligible pincodes</li>                        </ul>                    </div>                    <div>                        <h4 style="font-size: 0.9375rem; font-weight: 700; color: var(--text-primary); margin-bottom: var(--spacing-md);">Returns & Exchanges</h4>                        <ul style="font-size: 0.875rem; color: var(--text-secondary); line-height: 2; list-style: none; padding: 0;">                            <li style="display: flex; align-items: flex-start; gap: 0.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 0.125rem; color: var(--accent);"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>14-day easy return policy</li>                            <li style="display: flex; align-items: flex-start; gap: 0.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 0.125rem; color: var(--accent);"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>Items must be unworn, unwashed, with original tags</li>                            <li style="display: flex; align-items: flex-start; gap: 0.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 0.125rem; color: var(--accent);"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>Free return pickup for first return on each order</li>                            <li style="display: flex; align-items: flex-start; gap: 0.5rem;"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink: 0; margin-top: 0.125rem; color: var(--accent);"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>Refund to original payment method within 5–7 business days</li>                        </ul>                    </div>                    <div>                        <h4 style="font-size: 0.9375rem; font-weight: 700; color: var(--accent); margin-bottom: var(--spacing-md);">Need Help?</h4>                        <p style="font-size: 0.875rem; color: var(--text-secondary);">Contact our support team at <a href="mailto:support@bazaarbuzz.com" style="color: var(--accent); font-weight: 500;">support@bazaarbuzz.com</a></p>                    </div>                </div>            </div>        </div>    </div>    <!-- RECENTLY VIEWED -->    <% if(recentlyViewedProducts && recentlyViewedProducts.length > 0) { %>    <section style="margin-top: var(--spacing-2xl);" aria-labelledby="recently-viewed-heading">        <div class="section-header">            <h2 id="recently-viewed-heading" class="section-title">Recently Viewed</h2>        </div>        <div class="product-carousel" role="list">            <% recentlyViewedProducts.forEach((p, i) => { %>            <article class="carousel-card" role="listitem" style="animation: fadeIn var(--motion-normal) var(--motion-easing) <%= i * 0.06 %>s both;">                <a href="/user/viewProduct?productId=<%=p._id%>" class="product-card" tabindex="0">                    <div class="product-image">                        <img src="<%=p.images[0]%>" alt="" loading="lazy" />                        <% if(p.discount) { %>                        <div class="product-badge"><span class="badge badge-sale">-<%= p.discount %>%</span></div>                        <% } %>                    </div>                    <div class="product-info">                        <p class="product-brand"><%= p.brand || 'BazaarBuzz' %></p>                        <h3 class="product-name"><%= p.productName %></h3>                        <div class="product-price">                            <span class="product-price-current">₹<%= p.finalPrice.toLocaleString() %></span>                            <% if(p.discPrice !== p.productPrice) { %>                            <span class="product-price-original">₹<%= p.productPrice.toLocaleString() %></span>                            <% } %>                        </div>                    </div>                </a>            </article>            <% }) %>        </div>    </section>    <% } %>    <!-- YOU MAY ALSO LIKE (Bento Grid) -->    <% if(relatedProducts && relatedProducts.length > 0) { %>    <section style="margin-top: var(--spacing-2xl);" aria-labelledby="related-heading">        <div class="section-header">            <h2 id="related-heading" class="section-title">You May Also Like</h2>        </div>        <div class="product-carousel" role="list" aria-label="Related products">            <% relatedProducts.forEach((p, i) => { %>            <article class="carousel-card" role="listitem" style="animation: fadeIn var(--motion-normal) var(--motion-easing) <%= i * 0.06 %>s both;">                <a href="/user/viewProduct?productId=<%=p._id%>" class="product-card" style="height: 100%; display: flex; flex-direction: column;" tabindex="0">                    <div class="product-image" style="flex-shrink: 0;">                        <img src="<%=p.images[0]%>" alt="" loading="lazy" />                        <% if(p.hasOffer && p.discount) { %>                        <div class="product-badge">                            <span class="badge badge-sale">-<%= p.discount %>%</span>                            <span class="badge badge-offer"><%= p.offerName %> <%= p.offerDiscount %>%</span>                        </div>                        <% } else if(p.hasOffer) { %>                        <div class="product-badge"><span class="badge badge-offer"><%= p.offerName %> <%= p.offerDiscount %>%</span></div>                        <% } else if(p.discount) { %>                        <div class="product-badge"><span class="badge badge-sale">-<%= p.discount %>%</span></div>                        <% } %>                    </div>                    <div class="product-info" style="flex: 1; display: flex; flex-direction: column;">                        <p class="product-brand"><%= p.brand || 'BazaarBuzz' %></p>                        <h3 class="product-name"><%= p.productName %></h3>                        <div class="product-price" style="margin-top: auto;">                            <span class="product-price-current">₹<%= p.finalPrice.toLocaleString() %></span>                            <% if(p.discPrice !== p.productPrice) { %>                            <span class="product-price-original">₹<%= p.productPrice.toLocaleString() %></span>                            <% } %>                        </div>                        <% if(p.hasOffer) { %>                        <p class="product-offer-note">+ <%= p.offerName %> applied</p>                        <% } %>                    </div>                </a>            </article>            <% }) %>        </div>    </section>    <% } %></main><!-- IMAGE ZOOM MODAL --><div id="imageModal" role="dialog" aria-modal="true" aria-label="Product image zoom">    <button class="modal-close-top" onclick="closeImageModal()" aria-label="Close zoom">        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>    </button>    <button class="modal-nav modal-prev" onclick="navigateModal(-1)" aria-label="Previous image">        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>    </button>    <button class="modal-nav modal-next" onclick="navigateModal(1)" aria-label="Next image">        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>    </button>    <img id="modalImage" src="" alt="" />    <div class="modal-counter" id="modalCounter">1 / <%= product.images?.length || 1 %></div></div><!-- SIZE GUIDE MODAL --><div id="sizeGuideModal" class="modal-overlay" role="dialog" aria-modal="true" aria-label="Size guide">    <div class="modal-panel">        <div class="modal-header">            <h3 class="modal-title">Size Guide - <%= product.gender %></h3>            <button class="modal-close" onclick="closeSizeGuide()" aria-label="Close">                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>            </button>        </div>        <div class="modal-body">            <table class="size-table" role="table">                <thead>                    <tr role="row">                        <th role="columnheader" scope="col"><%= product.gender === 'men' ? "Men's Size" : product.gender === 'women' ? "Women's Size" : "Kids' Size" %></th>                        <th role="columnheader" scope="col">Chest (cm)</th>                        <th role="columnheader" scope="col">Waist (cm)</th>                        <th role="columnheader" scope="col">Hip (cm)</th>                    </tr>                </thead>                <tbody>                    <% if(product.gender === 'men') { %>                    <tr role="row"><td role="cell" style="font-weight: 600;">XS</td><td role="cell">86–91</td><td role="cell">71–76</td><td role="cell">86–91</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">S</td><td role="cell">91–97</td><td role="cell">76–81</td><td role="cell">91–97</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">M</td><td role="cell">97–102</td><td role="cell">81–86</td><td role="cell">97–102</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">L</td><td role="cell">102–107</td><td role="cell">86–91</td><td role="cell">102–107</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">XL</td><td role="cell">107–112</td><td role="cell">91–97</td><td role="cell">107–112</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">XXL</td><td role="cell">112–117</td><td role="cell">97–102</td><td role="cell">112–117</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">XXXL</td><td role="cell">117–122</td><td role="cell">102–107</td><td role="cell">117–122</td></tr>                    <% } else if(product.gender === 'women') { %>                    <tr role="row"><td role="cell" style="font-weight: 600;">XS</td><td role="cell">81–86</td><td role="cell">63–68</td><td role="cell">89–94</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">S</td><td role="cell">86–91</td><td role="cell">68–73</td><td role="cell">94–99</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">M</td><td role="cell">91–97</td><td role="cell">73–78</td><td role="cell">99–104</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">L</td><td role="cell">97–102</td><td role="cell">78–83</td><td role="cell">104–109</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">XL</td><td role="cell">102–107</td><td role="cell">83–88</td><td role="cell">109–114</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">XXL</td><td role="cell">107–112</td><td role="cell">88–93</td><td role="cell">114–119</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">XXXL</td><td role="cell">112–117</td><td role="cell">93–98</td><td role="cell">119–124</td></tr>                    <% } else { %>                    <tr role="row"><td role="cell" style="font-weight: 600;">2–3Y</td><td role="cell">56–58</td><td role="cell">54–56</td><td role="cell">58–60</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">4–5Y</td><td role="cell">60–62</td><td role="cell">56–58</td><td role="cell">62–64</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">6–7Y</td><td role="cell">64–66</td><td role="cell">58–60</td><td role="cell">66–68</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">8–9Y</td><td role="cell">68–70</td><td role="cell">60–62</td><td role="cell">70–72</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">10–11Y</td><td role="cell">72–74</td><td role="cell">62–64</td><td role="cell">74–76</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">12–13Y</td><td role="cell">76–78</td><td role="cell">64–66</td><td role="cell">78–80</td></tr>                    <tr role="row"><td role="cell" style="font-weight: 600;">14–15Y</td><td role="cell">80–82</td><td role="cell">66–68</td><td role="cell">82–84</td></tr>                    <% } %>                </tbody>            </table>            <p class="modal-note">Measurements are body measurements, not garment measurements. For best fit, measure yourself and compare.</p>        </div>    </div></div><!-- MOBILE STICKY BAR (single CTA, appears on scroll) --><div class="mobile-sticky-bar" id="mobileStickyBar" aria-hidden="true">    <div class="mobile-sticky-price">        <span class="mobile-sticky-label">Total</span>        <div style="display: flex; align-items: baseline; gap: var(--spacing-xs);">            <span class="mobile-sticky-amount">₹<%= offerDiscountedPrice %></span>            <% if(product.discount || offerDiscountValue) { %>            <span class="mobile-sticky-original">₹<%= product.productPrice.toLocaleString() %></span>            <% } %>        </div>    </div>    <button type="button" class="mobile-sticky-cta" onclick="document.getElementById('addToCartBtn').click()">Add to Cart</button></div><% } %>