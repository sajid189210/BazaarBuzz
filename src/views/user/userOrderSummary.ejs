<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Placed — BazaarBuzz</title>
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-white min-h-screen antialiased">
    <%- include('../partials/userHeader') %>
    <%- include('../partials/userNav') %>

    <div class="mx-auto max-w-[600px] px-4 sm:px-6 lg:px-8 pt-16 pb-24">
        <div class="text-center">
            <div class="mx-auto w-16 h-16 rounded-full bg-green-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h1 class="mt-6 text-2xl font-bold text-gray-900">Order Placed Successfully!</h1>
            <p class="mt-2 text-sm text-gray-500">Thank you for your purchase. Your order is being processed.</p>
        </div>

        <% if(order) { %>
        <div class="mt-10 rounded-xl border border-gray-200 p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-xs text-gray-400">Order ID</p>
                    <p class="text-sm font-medium text-gray-900"><%= order._id %></p>
                </div>
                <div class="text-right">
                    <p class="text-xs text-gray-400">Order Date</p>
                    <p class="text-sm font-medium text-gray-900"><%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                </div>
            </div>

            <hr class="my-4 border-gray-100">

            <div class="space-y-3">
                <% if(order.items && order.items.length > 0) { %>
                <% order.items.forEach(item => { %>
                <div class="flex gap-3">
                    <div class="w-14 h-14 rounded-lg overflow-hidden bg-gray-50 shrink-0">
                        <img src="<%= item.image || '/images/placeholder.jpg' %>" alt="" class="w-full h-full object-cover" />
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-gray-900 truncate"><%= item.name || 'Product' %></p>
                        <p class="text-xs text-gray-500">Qty: <%= item.quantity %> × ₹<%= item.unitPrice.toLocaleString() %></p>
                    </div>
                    <p class="text-sm font-semibold text-gray-900">₹<%= (item.finalPrice * item.quantity).toLocaleString() %></p>
                </div>
                <% }) %>
                <% } %>
            </div>

            <hr class="my-4 border-gray-100">

            <div class="flex justify-between text-base font-semibold text-gray-900">
                <span>Total Paid</span>
                <span>₹<%= order.total?.toLocaleString() || 0 %></span>
            </div>

            <div class="mt-3 text-xs text-gray-400">
                <p>Payment: <%= order.payment?.method || 'COD' %></p>
                <p>Delivery to: <%= order.shippingAddress?.contactName || '' %>, <%= order.shippingAddress?.district || '' %></p>
            </div>
        </div>
        <% } %>

        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/user/orders" class="rounded-lg bg-gray-900 px-6 py-3 text-sm font-semibold text-white text-center hover:bg-gray-800 transition-colors">View Orders</a>
            <a href="/" class="rounded-lg border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 text-center hover:border-gray-400 transition-colors">Continue Shopping</a>
        </div>
    </div>

    <%- include('../partials/userFooter') %>
</body>
</html>
