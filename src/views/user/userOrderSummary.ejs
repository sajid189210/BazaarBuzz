<% blocks.head=` <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>` %>
    <div class="mx-auto max-w-[1000px] px-3 xs:px-4 sm:px-6 lg:px-8 pt-4 sm:pt-6 pb-16">
        <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-8">
            <a href="/" class="hover:text-[var(--accent)] transition-colors btn-press">Home</a>
            <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i>
            <a href="/user/orders" class="hover:text-[var(--accent)] transition-colors btn-press">My Orders</a>
            <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i>
            <span class="text-gray-800 font-medium">Order #<%= String(order._id).slice(-8) %></span>
        </nav>

<% if(order) { %>
<% var now = new Date(); %>
<% var sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000); %>
            <div class="rounded-xl border border-gray-200 bg-white p-4 xs:p-5 shadow-sm mb-6">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div class="flex flex-wrap gap-4 xs:gap-6">
                        <div>
                            <p class="text-[10px] xs:text-xs text-gray-400 font-medium uppercase tracking-wider">Order ID</p>
                            <p class="text-xs xs:text-sm font-mono font-medium text-gray-900 mt-1 uppercase"><%= String(order._id).slice(-8) %></p>
                        </div>
                        <div>
                            <p class="text-[10px] xs:text-xs text-gray-400 font-medium uppercase tracking-wider">Date</p>
                            <p class="text-xs xs:text-sm text-gray-700 mt-1"><%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                        </div>
                        <div>
                            <p class="text-[10px] xs:text-xs text-gray-400 font-medium uppercase tracking-wider">Status</p>
                            <span class="inline-flex items-center gap-1.5 text-[10px] xs:text-xs font-semibold px-2.5 py-1 rounded-full mt-1
<%= order.status === 'delivered' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' :
                                   order.status === 'cancelled' ? 'bg-rose-50 text-rose-700 border border-rose-200' :
                                   order.status === 'payment_failed' ? 'bg-red-50 text-red-700 border border-red-200' :
                                   order.status === 'returned' || order.status === 'partially_returned' ? 'bg-blue-50 text-blue-700 border border-blue-200' :
                                   order.status === 'shipped' ? 'bg-sky-50 text-sky-700 border border-sky-200' :
                                   'bg-amber-50 text-amber-700 border border-amber-200' %>">
                                <span class="w-1.5 h-1.5 rounded-full
<%= order.status === 'delivered' ? 'bg-emerald-500' :
                                       order.status === 'cancelled' ? 'bg-rose-500' :
                                       order.status === 'payment_failed' ? 'bg-red-500' :
                                       order.status === 'returned' || order.status === 'partially_returned' ? 'bg-blue-500' :
                                       order.status === 'shipped' ? 'bg-sky-500' :
                                       'bg-amber-500' %>"></span>
<%= order.status === 'partially_delivered' ? 'Partially Delivered' :
                                   order.status === 'partially_returned' ? 'Partially Returned' :
                                   order.status === 'payment_failed' ? 'Payment Failed' :
                                   order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
                            </span>
                        </div>
                        <div>
                            <p class="text-[10px] xs:text-xs text-gray-400 font-medium uppercase tracking-wider">Payment</p>
                            <p class="text-xs xs:text-sm text-gray-700 mt-1">
<%= order.payment?.method || '-' %>
                                <span class="inline-block text-[10px] xs:text-xs font-semibold px-2 py-0.5 rounded-full ml-1.5
<%= order.payment?.status === 'paid' || order.payment?.status === 'refunded' ? 'bg-green-50 text-green-700' : order.payment?.status === 'failed' ? 'bg-red-50 text-red-700' : 'bg-amber-50 text-amber-700' %>">
<%= order.payment?.status ? order.payment.status.charAt(0).toUpperCase() + order.payment.status.slice(1) : '-' %>
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="rounded-xl border border-gray-200 bg-white p-4 xs:p-5 shadow-sm mb-6">
                <h3 class="text-sm xs:text-base font-semibold text-gray-900 mb-4">Items</h3>
                <div class="space-y-3">
<% order.items.forEach(item => { %>
                        <div class="flex gap-3 xs:gap-4 p-3 xs:p-4 rounded-lg bg-gray-50 items-center">
                            <div class="w-12 xs:w-16 h-16 xs:h-20 rounded-lg overflow-hidden bg-gray-200 shrink-0">
                                <img src="<%= item.image || '/images/placeholder.jpg' %>" alt="" class="w-full h-full object-cover" />
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs xs:text-sm font-medium text-gray-900"><%= item.name || 'Product' %></p>
                                <p class="text-[10px] xs:text-xs text-gray-500 mt-0.5">Size:<%= item.selectedSize %> · <span class="inline-flex items-center gap-1">Color: <span class="color-dot w-3 h-3 rounded-full inline-block border border-gray-300" style="background:<%= item.selectedColor || '#ccc' %>"></span><strong data-color-hex><%= item.selectedColor || 'N/A' %></strong></span></p>
                                <p class="text-[10px] xs:text-xs text-gray-500">Qty:<%= item.quantity %> · ₹<%= item.unitPrice?.toLocaleString('en-IN') || 0 %> per unit</p>
                                <span class="inline-flex items-center gap-1 text-[10px] xs:text-xs font-semibold px-2 py-0.5 rounded-full mt-1
<%= item.status === 'delivered' ? 'bg-emerald-50 text-emerald-700' :
                                       item.status === 'cancelled' ? 'bg-rose-50 text-rose-700' :
                                       item.status === 'returned' ? 'bg-blue-50 text-blue-700' :
                                       item.status === 'shipped' ? 'bg-sky-50 text-sky-700' :
                                       'bg-amber-50 text-amber-700' %>">
<%= item.status.charAt(0).toUpperCase() + item.status.slice(1) %>
                                </span>
<% if(item.return?.status === 'requested') { %>
                                    <span class="inline-flex items-center gap-1 text-[10px] xs:text-xs font-semibold px-2 py-0.5 rounded-full mt-1 bg-amber-50 text-amber-700 border border-amber-200">
                                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                                        Return Requested
                                    </span>
<% } else if(item.return?.status === 'approved') { %>
                                    <span class="inline-flex items-center gap-1 text-[10px] xs:text-xs font-semibold px-2 py-0.5 rounded-full mt-1 bg-emerald-50 text-emerald-700 border border-emerald-200">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                        Return Approved
                                    </span>
<% } else if(item.return?.status === 'rejected') { %>
                                    <span class="inline-flex items-center gap-1 text-[10px] xs:text-xs font-semibold px-2 py-0.5 rounded-full mt-1 bg-rose-50 text-rose-700 border border-rose-200">
                                        <span class="w-1.5 h-1.5 rounded-full bg-rose-500"></span>
                                        Return Rejected
                                    </span>
<% if(item.return?.reason) { %>
                                        <p class="text-[10px] xs:text-xs text-gray-500 mt-1 italic">Reason:<%= item.return.reason %></p>
<% } %>
<% } %>
                            </div>
                            <div class="text-right shrink-0">
                                <p class="text-xs xs:text-sm font-semibold text-gray-900">₹<%= (item.finalPrice * item.quantity).toLocaleString('en-IN') %></p>
<% if(item.status === 'processing' && order.payment?.status !== 'failed') { %>
                                    <button onclick="cancelOrderItem('<%= order._id %>', '<%= item._id %>')"
                                        class="mt-2 inline-flex items-center gap-1 text-[10px] xs:text-xs font-semibold text-red-600 hover:text-red-700 bg-white border border-red-300 hover:bg-red-50 px-2.5 py-1.5 rounded-lg transition-colors">
                                        <i class="fa-solid fa-xmark"></i>
                                        Cancel
                                    </button>
<% } %>
<% if(item.status === 'delivered' && item.deliveredAt && new Date(item.deliveredAt) >= sevenDaysAgo && !item.return?.status) { %>
                                    <button onclick="requestReturn('<%= order._id %>', '<%= item._id %>')"
                                        class="mt-2 inline-flex items-center gap-1 text-[10px] xs:text-xs font-semibold text-blue-600 hover:text-blue-700 bg-white border border-blue-300 hover:bg-blue-50 px-2.5 py-1.5 rounded-lg transition-colors">
                                        <i class="fa-solid fa-rotate-left"></i>
                                        Return
                                    </button>
<% } %>
                            </div>
                        </div>
<% }) %>
                </div>
            </div>

            <div class="rounded-xl border border-gray-200 bg-white p-4 xs:p-5 shadow-sm mb-6">
                <h3 class="text-sm xs:text-base font-semibold text-gray-900 mb-4">Price Summary</h3>
                <div class="space-y-2 text-xs xs:text-sm">
                    <div class="flex justify-between text-gray-600">
                        <span>Subtotal</span>
                        <span>₹<%= order.subtotal?.toLocaleString('en-IN') || 0 %></span>
                    </div>
<% if(order.productDiscount > 0) { %>
                        <div class="flex justify-between text-green-600">
                            <span>Product Discount</span>
                            <span>-₹<%= order.productDiscount.toLocaleString('en-IN') %></span>
                        </div>
<% } %>
<% if(order.coupon?.discount > 0) { %>
                        <div class="flex justify-between text-green-600">
                            <span>Coupon Discount</span>
                            <span>-₹<%= order.coupon.discount.toLocaleString('en-IN') %></span>
                        </div>
<% } %>
<% if(order.tax > 0) { %>
                        <div class="flex justify-between text-gray-600">
                            <span>Tax</span>
                            <span>₹<%= order.tax.toLocaleString('en-IN') %></span>
                        </div>
<% } %>
                    <hr class="border-gray-200">
                    <div class="flex justify-between text-sm xs:text-base font-semibold text-gray-900">
                        <span>Total</span>
                        <span>₹<%= order.total?.toLocaleString('en-IN') || 0 %></span>
                    </div>
                </div>
            </div>

<% if(order.shippingAddress) { %>
                <div class="rounded-xl border border-gray-200 bg-white p-4 xs:p-5 shadow-sm mb-6">
                    <h3 class="text-sm xs:text-base font-semibold text-gray-900 mb-4">Delivery Address</h3>
                    <div class="text-xs xs:text-sm text-gray-700 space-y-1">
                        <p class="font-medium text-gray-900"><%= order.shippingAddress.contactName %></p>
                        <p><%= [order.shippingAddress.building, order.shippingAddress.street].filter(Boolean).join(', ') %></p>
                        <p><%= order.shippingAddress.landmark ? order.shippingAddress.landmark + ', ' : '' %><%= order.shippingAddress.district %>,<%= order.shippingAddress.state %> —<%= order.shippingAddress.pincode %></p>
                        <p>Phone:<%= order.shippingAddress.contactNumber %></p>
                    </div>
                </div>
<% } %>

            <div class="flex flex-col sm:flex-row gap-3 justify-center">
<% if(order.items.some(item => item.status === 'delivered')) { %>
                    <button onclick="downloadInvoice()" id="invoiceBtn" data-order-id="<%= order._id %>"
                        class="inline-flex items-center justify-center gap-2 rounded-lg bg-emerald-600 px-5 xs:px-6 py-2.5 xs:py-3 text-xs xs:text-sm font-semibold text-white hover:bg-emerald-700 transition-colors btn-press">
                        <i class="fa-solid fa-file-invoice"></i>
                        Download Invoice
                    </button>
<% } %>
<% if(order.payment?.status === 'failed' && order.payment?.method === 'razorpay') { %>
                    <button onclick="retryPayment('<%= order._id %>')" id="retryBtn"
                        class="inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-5 xs:px-6 py-2.5 xs:py-3 text-xs xs:text-sm font-semibold text-white hover:bg-blue-700 transition-colors btn-press">
                        <i class="fa-solid fa-rotate-right"></i>
                        Retry Payment
                    </button>
<% } %>
                <a href="/user/orders" class="rounded-lg bg-gray-900 px-5 xs:px-6 py-2.5 xs:py-3 text-xs xs:text-sm font-semibold text-white text-center hover:bg-gray-800 transition-colors btn-press">View Orders</a>
                <a href="/" class="rounded-lg border border-gray-300 px-5 xs:px-6 py-2.5 xs:py-3 text-xs xs:text-sm font-semibold text-gray-700 text-center hover:border-gray-400 transition-colors btn-press">Continue Shopping</a>
            </div>
<% } else { %>
            <div class="text-center py-20 text-gray-400">
                <i class="fa-regular fa-face-frown text-5xl text-gray-300 mb-3"></i>
                <p>Order not found</p>
            </div>
<% } %>
    </div>
<% blocks.scripts=`
    <script src="/javascript/ntc.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof ntc === 'undefined') return;
            document.querySelectorAll('[data-color-hex]').forEach(function(el) {
                var hex = el.textContent.trim();
                if (!hex) return;
                var match = ntc.name(hex);
                if (match && match[1]) {
                    el.textContent = match[1];
                    var dot = el.previousElementSibling;
                    if (dot && dot.classList.contains('color-dot')) {
                        dot.style.backgroundColor = match[0];
                    }
                }
            });
        });
    </script>
    <script>
        var _invoiceLastClick = 0;
        async function downloadInvoice() {
            var now = Date.now();
            if (now - _invoiceLastClick < 2000) return;
            _invoiceLastClick = now;
            var btn = document.getElementById('invoiceBtn');
            if (btn.disabled) return;
            var orderId = btn.dataset.orderId;
            btn.disabled = true;
            btn.innerHTML = 'Generating... <i class="fa-solid fa-spinner fa-spin"></i>';

            try {
                var res = await fetch('/user/orders/invoice?orderId=' + orderId);
                if (!res.ok) {
                    var data = await res.json();
                    Swal.fire({ icon: 'error', title: 'Error', text: data.message || 'Failed to generate invoice.' });
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-file-invoice"></i> Download Invoice';
                    return;
                }
                var blob = await res.blob();
                var url = URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url;
                a.download = 'invoice_' + orderId + '.pdf';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            } catch (e) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong. Please try again.' });
            }

            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-file-invoice"></i> Download Invoice';
        }
    </script>
    <script src="/javascript/user/userOrderView.js"></script>` %>
