<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmed</title>
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/dark-theme.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
    <div class="relative font-[poppins]">
        <%- include('../partials/userHeader') %>

        <div class="absolute top-[60px] w-full min-h-screen bg-[#F5F6FA]">
            <div class="max-w-3xl mx-auto px-4 py-8">

                <!-- Success Banner -->
                <div class="bg-white rounded-2xl shadow-sm p-8 text-center mb-6">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </div>
                    <h1 class="text-2xl font-bold text-gray-900">Order Confirmed!</h1>
                    <p class="text-gray-500 mt-2">Thanks for your order, <span class="font-semibold text-gray-800"><%= user.userName %></span></p>
                </div>

                <!-- Invoice Card -->
                <div class="bg-white rounded-2xl shadow-sm p-6 lg:p-8">
                    <!-- Header -->
                    <div class="flex justify-between items-start pb-6 border-b border-gray-200">
                        <div>
                            <h2 class="text-xl font-bold text-gray-900">INVOICE</h2>
                            <p class="text-sm text-gray-400 mt-1">#<%= order._id %></p>
                        </div>
                        <div class="text-right">
                            <p class="text-sm text-gray-400">Ordered on</p>
                            <p class="text-sm font-medium text-gray-700"><%= order.createdAt.toLocaleDateString() %></p>
                        </div>
                    </div>

                    <!-- Shipping & Payment -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 py-6 border-b border-gray-200">
                        <div>
                            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Shipping To</h3>
                            <p class="text-sm font-medium text-gray-800"><%= user.userName %></p>
                            <p class="text-sm text-gray-500"><%= order.shippingAddress.building %></p>
                            <p class="text-sm text-gray-500"><%= order.shippingAddress.street %>, <%= order.shippingAddress.landmark %></p>
                            <p class="text-sm text-gray-500"><%= order.shippingAddress.district %>, <%= order.shippingAddress.state %> - <%= order.shippingAddress.pincode %></p>
                        </div>
                        <div>
                            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Payment</h3>
                            <p class="text-sm font-medium text-gray-800"><%= order.paymentMethod %></p>
                            <p class="text-xs text-gray-400 mt-1">Order ID: <%= order._id %></p>
                        </div>
                    </div>

                    <!-- Items Table -->
                    <div class="py-6 border-b border-gray-200">
                        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">Items Ordered</h3>
                        <table class="w-full">
                            <thead>
                                <tr class="text-xs text-gray-400 uppercase border-b border-gray-100">
                                    <th class="text-left pb-2 font-medium">Item</th>
                                    <th class="text-center pb-2 font-medium">Qty</th>
                                    <th class="text-right pb-2 font-medium">Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% order.orderedProducts.forEach((item, index)=> { %>
                                <tr class="border-b border-gray-50">
                                    <td class="py-3">
                                        <p class="text-sm font-medium text-gray-800"><%= item.product.productName %></p>
                                        <p class="text-xs text-gray-400"><%= item.selectedColor %> / <%= item.selectedSize %></p>
                                    </td>
                                    <td class="py-3 text-center text-sm text-gray-600"><%= item.quantity %></td>
                                    <td class="py-3 text-right text-sm text-gray-800">₹<%= item.totalPay %></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Totals -->
                    <div class="pt-6">
                        <div class="flex justify-between text-sm mb-2">
                            <span class="text-gray-500">Subtotal</span>
                            <span class="text-gray-700">₹<%= originalTotalPrice %></span>
                        </div>
                        <div class="flex justify-between text-sm mb-2">
                            <span class="text-gray-500">Discount</span>
                            <span class="text-red-500">-₹<%= totalDiscountApplied %></span>
                        </div>
                        <div class="flex justify-between text-sm mb-4">
                            <span class="text-gray-500">Delivery</span>
                            <span class="text-gray-700"><%= totalPay < 1000 ? '₹40' : 'Free' %></span>
                        </div>
                        <div class="flex justify-between text-base font-bold pt-4 border-t border-gray-200">
                            <span class="text-gray-900">Total</span>
                            <span class="text-gray-900">₹<%= totalPay %></span>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex gap-3 justify-center mt-6">
                    <a href="/" class="px-6 py-2.5 border border-gray-300 text-gray-600 text-sm font-semibold rounded-xl hover:bg-gray-50 transition-colors">Back to Home</a>
                    <a href="/user/orders" class="px-6 py-2.5 bg-pink-500 hover:bg-pink-600 text-white text-sm font-semibold rounded-xl transition-colors">View Orders</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>