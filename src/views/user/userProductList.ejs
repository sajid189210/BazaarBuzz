<% blocks.head=` <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>` %>
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 pt-6 pb-12"> <!-- Breadcrumbs -->
        <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-6"> <a href="/"
                class="hover:text-[var(--accent)] transition-colors btn-press">Home</a> <svg
                xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5">
                <polyline points="9 18 15 12 9 6" />
            </svg> <span class="text-gray-800 font-medium">Products</span> </nav>
        <div class="flex gap-8"> <!-- Sidebar Filters -->
            <aside id="dropdown-menu" class="hidden md:block w-64 shrink-0">
                <div class="sticky top-24 space-y-6">
                    <div class="flex items-center justify-between">
                        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider">Filters</h3> <button
                            onclick="clearFilters()"
                            class="text-xs text-[var(--accent)] hover:text-[var(--accent)] font-medium transition-colors btn-press">Clear
                            All</button>
                    </div>
                    <div>
                        <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Categories</h4>
                        <div class="space-y-2">
                            <% if(categories && categories.length> 0) { %> <% categories.forEach(category=> { %> <label
                                        class="flex items-center gap-2 cursor-pointer group"> <input type="radio"
                                            name="category" value="<%=category.title%>"
                                            data-collection-id="<%=collectionId%>"
                                            class="w-4 h-4 text-[var(--accent)] border-gray-300 focus:ring-rose-400">
                                        <span class="text-sm text-gray-600 group-hover:text-gray-900 transition-colors">
                                            <%= category.title %>
                                        </span> </label>
                                    <% }) %>
                                        <% } else { %>
                                            <p class="text-sm text-gray-400">No categories</p>
                                            <% } %>
                        </div>
                    </div>
                    <hr class="border-gray-100">
                    <div>
                        <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Price</h4>
                        <div class="space-y-2"> <label class="flex items-center gap-2 cursor-pointer group"> <input
                                    type="radio" name="price" value="high" data-collection-id="<%=collectionId%>"
                                    class="w-4 h-4 text-[var(--accent)] border-gray-300 focus:ring-rose-400"> <span
                                    class="text-sm text-gray-600 group-hover:text-gray-900 transition-colors">High to
                                    Low</span> </label> <label class="flex items-center gap-2 cursor-pointer group">
                                <input type="radio" name="price" value="low" data-collection-id="<%=collectionId%>"
                                    class="w-4 h-4 text-[var(--accent)] border-gray-300 focus:ring-rose-400"> <span
                                    class="text-sm text-gray-600 group-hover:text-gray-900 transition-colors">Low to
                                    High</span> </label> </div>
                    </div>
                    <hr class="border-gray-100">
                    <div>
                        <h4 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Name</h4>
                        <div class="space-y-2"> <label class="flex items-center gap-2 cursor-pointer group"> <input
                                    type="radio" name="name" value="asc" data-collection-id="<%=collectionId%>"
                                    class="w-4 h-4 text-[var(--accent)] border-gray-300 focus:ring-rose-400"> <span
                                    class="text-sm text-gray-600 group-hover:text-gray-900 transition-colors">A-Z</span>
                            </label> <label class="flex items-center gap-2 cursor-pointer group"> <input type="radio"
                                    name="name" value="desc" data-collection-id="<%=collectionId%>"
                                    class="w-4 h-4 text-[var(--accent)] border-gray-300 focus:ring-rose-400"> <span
                                    class="text-sm text-gray-600 group-hover:text-gray-900 transition-colors">Z-A</span>
                            </label> </div>
                    </div> <button onclick="applyFilters('<%= collectionId%>')" type="button"
                        class="w-full rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors btn-press">Apply
                        Filters</button>
                </div>
            </aside> <!-- Mobile Filter Button --> <button id="options-menu"
                class="md:hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-40 rounded-full bg-gray-900 text-white px-6 py-3 text-sm font-semibold shadow-lg hover:bg-gray-800 transition-colors btn-press">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 inline mr-2">
                    <line x1="4" y1="21" x2="4" y2="14" />
                    <line x1="4" y1="10" x2="4" y2="3" />
                    <line x1="12" y1="21" x2="12" y2="12" />
                    <line x1="12" y1="8" x2="12" y2="3" />
                    <line x1="20" y1="21" x2="20" y2="16" />
                    <line x1="20" y1="12" x2="20" y2="3" />
                    <line x1="1" y1="14" x2="7" y2="14" />
                    <line x1="9" y1="8" x2="15" y2="8" />
                    <line x1="17" y1="16" x2="23" y2="16" />
                </svg> Filters </button> <!-- Products Grid -->
            <main class="flex-1 min-w-0">
                <div id="productCard" class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-6">
                    <% if(products && products.length) { %>
                        <% products.forEach((product)=> { var discPrice = product.discount ?
                            Math.round(product.productPrice - (product.productPrice * product.discount / 100)) :
                            product.productPrice; var matchedOffer = (offers && offers.length) ? offers.find(function(o)
                            { return o.brandName === product.brand; }) : null; var finalPrice = discPrice; var hasOffer
                            = matchedOffer && matchedOffer.discount > 0; if (hasOffer) { finalPrice =
                            Math.round(discPrice - (discPrice * matchedOffer.discount / 100)); } %> <div class="group">
                                <a href="/user/viewProduct?productId=<%=product._id%>" class="block btn-press">
                                    <div class="relative overflow-hidden rounded-xl bg-gray-50 aspect-[3/4]"> <img
                                            src="<%=product.images[0]%>" alt="<%=product.productName%>"
                                            class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out" />
                                        <% if(hasOffer && product.discount) { %>
                                            <div class="absolute top-3 left-3 flex gap-1"> <span
                                                    class="bg-[var(--accent)] text-white text-[10px] font-semibold px-2.5 py-1 rounded-full">-
                                                    <%= product.discount %>% off
                                                </span> <span
                                                    class="bg-green-600 text-white text-[10px] font-semibold px-2.5 py-1 rounded-full">
                                                    <%= matchedOffer.offerName %> -<%= matchedOffer.discount %>%
                                                </span> </div>
                                            <% } else if(hasOffer) { %>
                                                <div
                                                    class="absolute top-3 left-3 bg-green-600 text-white text-[10px] font-semibold px-2.5 py-1 rounded-full">
                                                    <%= matchedOffer.offerName %> -<%= matchedOffer.discount %>% off
                                                </div>
                                                <% } else if(product.discount) { %>
                                                    <div
                                                        class="absolute top-3 left-3 bg-[var(--accent)] text-white text-[10px] font-semibold px-2.5 py-1 rounded-full">
                                                        -<%= product.discount %>% off </div>
                                                    <% } %>
                                                        <div
                                                            class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300">
                                                        </div>
                                    </div>
                                    <div class="mt-3 space-y-1">
                                        <p class="text-[11px] text-gray-400 uppercase tracking-widest">
                                            <%= product.brand || 'BazaarBuzz' %>
                                        </p>
                                        <h3 class="text-sm font-medium text-gray-800 truncate">
                                            <%= product.productName %>
                                        </h3>
                                        <div class="flex items-center gap-2">
                                            <% if(finalPrice !==product.productPrice) { %> <span
                                                    class="text-sm font-semibold text-gray-900">₹<%=
                                                        finalPrice.toLocaleString() %></span> <span
                                                    class="text-xs text-gray-400 line-through">₹<%=
                                                        product.productPrice.toLocaleString() %></span>
                                                <% } else { %> <span class="text-sm font-semibold text-gray-900">₹<%=
                                                            product.productPrice.toLocaleString() %></span>
                                                    <% } %>
                                        </div>
                                        <% if(hasOffer) { %>
                                            <p class="text-[10px] text-green-600 font-medium">+ <%=
                                                    matchedOffer.offerName %> applied</p>
                                            <% } %>
                                    </div>
                                </a>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="col-span-full flex flex-col items-center justify-center py-20"> <svg
                                            xmlns="http://www.w3.org/2000/svg" width="64" height="64"
                                            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"
                                            stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 mb-4">
                                            <circle cx="11" cy="11" r="8" />
                                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                                        </svg>
                                        <h3 class="text-lg font-semibold text-gray-500">No products found</h3>
                                        <p class="text-sm text-gray-400 mt-1">Try adjusting your search or filter
                                            criteria</p>
                                    </div>
                                    <% } %>
                </div>
            </main>
        </div>
    </div>
    <% blocks.scripts=` <script> document.querySelector('#options-menu')?.addEventListener('click', () => { const menu =
        document.querySelector('#dropdown-menu'); menu.classList.remove('hidden'); menu.classList.add('fixed',
        'inset-0', 'z-50', 'w-full', 'bg-white', 'p-6', 'overflow-y-auto');
        document.querySelector('#options-menu').classList.add('hidden');
        menu.querySelector('.sticky').classList.remove('sticky'); }); document.addEventListener('click', function(e) {
        const menu = document.querySelector('#dropdown-menu'); if (menu?.classList.contains('fixed')) { const closeBtn =
        document.createElement('button'); closeBtn.className = 'absolute top-4 right-4 text-gray-400
        hover:text-gray-600'; closeBtn.innerHTML = '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24"
            stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>'; closeBtn.onclick = function() { menu.classList.add('hidden'); menu.classList.remove('fixed', 'inset-0',
        'z-50', 'w-full', 'bg-white', 'p-6', 'overflow-y-auto');
        document.querySelector('#options-menu')?.classList.remove('hidden'); }; if
        (!menu.querySelector('.close-filter-btn')) { closeBtn.classList.add('close-filter-btn'); menu.prepend(closeBtn);
        } } }); </script>
        <script src="/javascript/user/homesearch.js"></script>
        <script src="/javascript/user/buttonSearch.js"></script>
        <script>        async function clearFilters() { window.location.reload(); } async function applyFilters(collectionId) {
                try {
                    const categoryFilter = getCheckedValue('input[name="category"]'); const priceFilter = getCheckedValue('input[name="price"]'); const nameFilter = getCheckedValue('input[name="name"]'); const response = await fetch(\`/user/filterProductList/\${collectionId}?categoryFilter=\${encodeURIComponent(categoryFilter)}&priceFilter=\${encodeURIComponent(priceFilter)}&nameFilter=\${encodeURIComponent(nameFilter)}\`, {                    method: 'GET', headers: { 'Accept': 'application/json' }                });                if (!response.ok) throw new Error("The response was not OK.");                const data = await response.json();                if (!data.success) {                    await Swal.fire({ title: 'Invalid', text: data.message, icon: 'info', confirmButtonText: 'Ok' });                    return;                }                const productListElement = document.querySelector('#productCard');                productListElement.innerHTML = '';                if (data.products.length === 0) {                    productListElement.innerHTML = \`<div class="col-span-full flex flex-col items-center justify-center py-20"><svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 mb-4"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><h3 class="text-lg font-semibold text-gray-500">No products found</h3><p class="text-sm text-gray-400 mt-1">Try adjusting your search or filter criteria</p></div>\`;                    return;                }                data.products.forEach(product => {                    const discPrice = Math.round(product.productPrice * (1 - (parseFloat(product.discount) / 100)));                    const el = document.createElement('div');                    el.className = 'group';                    el.innerHTML = \`<a href="/user/viewProduct?productId=\${product._id}" class="block btn-press"><div class="relative overflow-hidden rounded-xl bg-gray-50 aspect-[3/4]"><img src="\${product.images[0]}" alt="\${product.productName}" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out" />\${product.discount ? \`<div class="absolute top-3 left-3 bg-[var(--accent)] text-white text-[10px] font-semibold px-2.5 py-1 rounded-full">-\${product.discount}% off</div>\` : ''}<div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-300"></div></div><div class="mt-3 space-y-1"><p class="text-[11px] text-gray-400 uppercase tracking-widest">\${product.brand || 'BazaarBuzz'}</p><h3 class="text-sm font-medium text-gray-800 truncate">\${product.productName}</h3><div class="flex items-center gap-2">\${product.discount ? \`<span class="text-sm font-semibold text-gray-900">₹\${discPrice.toLocaleString()}</span><span class="text-xs text-gray-400 line-through">₹\${product.productPrice.toLocaleString()}</span>\` : \`<span class="text-sm font-semibold text-gray-900">₹\${product.productPrice.toLocaleString()}</span>\`}</div></div></a>\`;                    productListElement.appendChild(el);                });            } catch (err) { console.log(err); alert('Error'); }        }        function getCheckedValue(selector) {            const elements = document.querySelectorAll(selector);            let selectedValue;            elements.forEach(el => { if (el.checked) selectedValue = el.value; });            return selectedValue || '';        }        async function addToWishList(productId) {            try {                if (!productId) { alert('productId not found'); return; }                const response = await fetch('/user/wishlist', {                    method: 'PUT', headers: { 'Content-Type': 'application/json' },                    body: JSON.stringify({ productId })                });                const data = await response.json();                if (!data.session) {                    await Swal.fire({ title: 'Sign In!', text: data.message, icon: 'info', confirmButtonText: 'Ok' });                    window.location.href = data.redirectUrl; return;                }                if (!data.success) {                    await Swal.fire({ title: 'Failed', text: data.message, icon: 'warning', confirmButtonText: 'Ok' });                    if (data.redirectUrl) window.location.href = data.redirectUrl; return;                }                Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 2000, timerProgressBar: true }).fire({ icon: 'success', title: data.message });            } catch (err) { console.log(err); alert('Error'); }        }    </script>
        ` %>