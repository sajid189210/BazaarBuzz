<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up — BazaarBuzz</title>
    <link rel="shortcut icon" href="/uploads/favicon-32x32.png" type="image/x-icon">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="min-h-screen bg-gray-50 antialiased">
    <div class="flex min-h-screen">
        <div class="hidden lg:flex lg:w-1/2 relative bg-gray-900">
            <div class="absolute inset-0 bg-cover bg-center" style="background-image: url(/images/Signup_image.jpg);"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-gray-900/80 to-transparent"></div>
            <div class="relative z-10 flex flex-col justify-between p-12">
                <a href="/" class="text-2xl font-bold text-white">Bazaar<span class="text-rose-400">Buzz</span></a>
                <div>
                    <h1 class="text-4xl font-bold text-white leading-tight">Join the<br>BazaarBuzz family.</h1>
                    <p class="mt-3 text-base text-gray-300 max-w-sm">Create an account and start discovering styles you'll love.</p>
                </div>
            </div>
        </div>

        <div class="flex flex-1 items-center justify-center px-6 py-12">
            <div class="w-full max-w-md">
                <div class="lg:hidden mb-8">
                    <a href="/" class="text-2xl font-bold text-gray-900">Bazaar<span class="text-rose-500">Buzz</span></a>
                </div>

                <h2 class="text-2xl font-bold text-gray-900">Create Account</h2>
                <p class="mt-1 text-sm text-gray-500">Please fill out all the fields below.</p>

                <form id="signUpForm" class="mt-8 space-y-5">
                    <div>
                        <label for="username" class="block text-sm font-medium text-gray-700">Username</label>
                        <div id="usernameError" class="error-message hidden text-xs text-red-500"></div>
                        <input type="text" name="username" id="username" required
                            class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                    </div>

                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700">Email Address</label>
                        <span class="text-red-400 text-xs block bg-sky-500"><%= authErrors %></span>
                        <div id="emailError" class="error-message hidden text-xs text-red-500"></div>
                        <input type="email" name="email" id="email" required
                            class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                    </div>

                    <div>
                        <label for="password" class="block text-sm font-medium text-gray-700">Password</label>
                        <div id="passwordError" class="error-message hidden text-xs text-red-500"></div>
                        <input type="password" name="password" id="password" required
                            class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                    </div>

                    <div>
                        <label for="confirmPassword" class="block text-sm font-medium text-gray-700">Confirm Password</label>
                        <div id="confirmPasswordError" class="error-message hidden text-xs text-red-500"></div>
                        <input type="password" name="confirmPassword" id="confirmPassword" required
                            class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                    </div>

                    <button type="submit"
                        class="w-full rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">Create Account</button>
                </form>

                <p class="mt-8 text-center text-sm text-gray-500">
                    Already have an account?
                    <a href="/user/signIn" class="font-medium text-rose-500 hover:text-rose-600 transition-colors">Sign In</a>
                </p>
            </div>
        </div>
    </div>

    <!-- OTP Verification Modal -->
    <div id="otpModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeModal()"></div>
        <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-md mx-4 p-8">
            <button type="button" onclick="closeModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            <div class="text-center">
                <h3 class="text-xl font-bold text-gray-900">Email Verification</h3>
                <p class="mt-2 text-sm text-gray-500">We have sent a code to your email</p>
            </div>
            <form id="OTPForm" class="mt-8">
                <div class="flex justify-center gap-3" id="otpInputsContainer" role="group" aria-label="Enter 4-digit verification code">
                    <input class="otp-input w-14 h-14 text-center text-lg font-semibold rounded-xl border border-gray-300 bg-white outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 transition-all" type="text" name="otp" maxlength="1" inputmode="numeric" autocomplete="one-time-code" aria-label="Digit 1" />
                    <input class="otp-input w-14 h-14 text-center text-lg font-semibold rounded-xl border border-gray-300 bg-white outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 transition-all" type="text" name="otp" maxlength="1" inputmode="numeric" autocomplete="one-time-code" aria-label="Digit 2" />
                    <input class="otp-input w-14 h-14 text-center text-lg font-semibold rounded-xl border border-gray-300 bg-white outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 transition-all" type="text" name="otp" maxlength="1" inputmode="numeric" autocomplete="one-time-code" aria-label="Digit 3" />
                    <input class="otp-input w-14 h-14 text-center text-lg font-semibold rounded-xl border border-gray-300 bg-white outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 transition-all" type="text" name="otp" maxlength="1" inputmode="numeric" autocomplete="one-time-code" aria-label="Digit 4" />
                    <input type="hidden" id="modalOtpId">
                </div>
                <button type="submit" id="otpVerifyBtn" disabled
                    class="mt-8 w-full rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors opacity-50 cursor-not-allowed">Verify OTP</button>
                <div class="mt-4 flex items-center justify-center gap-2 text-sm text-gray-500">
                    <button type="button" class="hidden text-rose-500 hover:text-rose-600 font-medium transition-colors" id="resendOTP">Resend OTP</button>
                    <span id="timer" aria-live="polite">1:00</span>
                </div>
            </form>
        </div>
    </div>

    <script src="/javascript/user/userSignUpPage.js"></script>
</body>
</html>
