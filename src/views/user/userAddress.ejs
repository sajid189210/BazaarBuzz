<% layout('layout') -%>
<% blocks.head = `
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
` %>

<div class="mx-auto max-w-[800px] px-4 sm:px-6 lg:px-8 pt-6 pb-16">
    <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-rose-500 transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-gray-800 font-medium">My Address</span>
    </nav>

    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl lg:text-3xl font-bold text-gray-900">My Address</h1>
        <button onclick="openAddressModal()" class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">+ Add Address</button>
    </div>

    <% if(userDetails && userDetails.addressId && userDetails.addressId.length > 0) { %>
    <div class="space-y-3">
        <% userDetails.addressId.forEach(addr => { %>
        <div class="rounded-xl border border-gray-200 bg-white p-5 hover:border-gray-300 transition-colors">
            <div class="flex items-start justify-between">
                <div class="text-sm">
                    <p class="font-semibold text-gray-900"><%= addr.contactName %></p>
                    <p class="text-gray-500 mt-0.5"><%= addr.building %>, <%= addr.street %>, <%= addr.district %>, <%= addr.state %> — <%= addr.pincode %></p>
                    <p class="text-gray-500">Phone: <%= addr.contactNumber %></p>
                </div>
                <div class="flex gap-2 shrink-0">
                    <button onclick="editAddress('<%= addr._id %>')" class="text-xs font-medium text-rose-500 hover:text-rose-600 transition-colors">Edit</button>
                    <button onclick="deleteAddress('<%= addr._id %>')" class="text-xs font-medium text-gray-400 hover:text-red-500 transition-colors">Remove</button>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
    <% } else { %>
    <div class="flex flex-col items-center justify-center py-20">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 mb-4"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <h3 class="text-lg font-semibold text-gray-500">No addresses saved</h3>
        <button onclick="openAddressModal()" class="mt-4 text-sm font-medium text-rose-500 hover:text-rose-600 transition-colors">Add Your First Address</button>
    </div>
    <% } %>
</div>

<!-- Address Modal -->
<div id="addressModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeAddressModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-lg mx-4 p-8 max-h-[90vh] overflow-y-auto">
        <button type="button" onclick="closeAddressModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <h2 id="addressModalTitle" class="text-xl font-bold text-gray-900 mb-6">Add Address</h2>
        <form id="addressForm" class="space-y-4">
            <input type="hidden" name="addressId" id="addressId">
            <div>
                <label for="contactName" class="block text-sm font-medium text-gray-700">Full Name</label>
                <input type="text" name="contactName" id="contactName" required
                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
            </div>
            <div>
                <label for="contactNumber" class="block text-sm font-medium text-gray-700">Phone Number</label>
                <input type="text" name="contactNumber" id="contactNumber" required
                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
            </div>
            <div>
                <label for="pincode" class="block text-sm font-medium text-gray-700">Pincode</label>
                <input type="text" name="pincode" id="pincode" required
                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
            </div>
            <div>
                <label for="building" class="block text-sm font-medium text-gray-700">Building / Apartment</label>
                <input type="text" name="building" id="building" required
                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
            </div>
            <div>
                <label for="street" class="block text-sm font-medium text-gray-700">Street</label>
                <input type="text" name="street" id="street" required
                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
            </div>
            <div>
                <label for="landmark" class="block text-sm font-medium text-gray-700">Landmark</label>
                <input type="text" name="landmark" id="landmark"
                    class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label for="district" class="block text-sm font-medium text-gray-700">City / District</label>
                    <input type="text" name="district" id="district" required
                        class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                </div>
                <div>
                    <label for="state" class="block text-sm font-medium text-gray-700">State</label>
                    <input type="text" name="state" id="state" required
                        class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                </div>
            </div>
            <button type="submit"
                class="w-full rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">Save Address</button>
        </form>
    </div>
</div>

<% blocks.scripts = `
    <script src="/javascript/user/userAddress.js"></script>
` %>