<% blocks.head=` <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>` %>
<div class="mx-auto max-w-[800px] px-4 sm:px-6 lg:px-8 pt-6 pb-16">
  <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-8">
    <a href="/" class="hover:text-[var(--accent)] transition-colors btn-press">Home</a>
    <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i>
    <span class="text-gray-800 font-medium">My Address</span>
  </nav>
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900">My Address</h1>
    <button onclick="openAddressModal()" class="rounded-lg bg-gray-900 px-5 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors btn-press">+ Add Address</button>
  </div>

  <% if(userDetails && userDetails.addressId && userDetails.addressId.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% userDetails.addressId.forEach(addr => { %>
    <div class="rounded-xl border border-gray-200 bg-white p-5 hover:border-gray-300 hover:shadow-sm transition-all">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1 min-w-0 space-y-3">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
              <i class="fa-regular fa-user text-gray-500"></i>
            </div>
            <div>
              <p class="font-semibold text-gray-900"><%= addr.contactName %></p>
              <p class="text-xs text-gray-500 flex items-center gap-1">
                <i class="fa-solid fa-phone text-xs"></i>
                <%= addr.contactNumber %>
              </p>
            </div>
          </div>

          <div class="flex gap-2">
            <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
              <i class="fa-solid fa-location-dot text-gray-500"></i>
            </div>
            <div class="text-sm text-gray-600 leading-relaxed">
              <p><%= addr.building %>, <%= addr.street %></p>
              <p><%= addr.district %>, <%= addr.state %> — <%= addr.pincode %></p>
              <% if(addr.landmark) { %>
              <p class="text-xs text-gray-400 mt-0.5 flex items-center gap-1">
                <i class="fa-solid fa-triangle-exclamation text-xs"></i>
                Near: <%= addr.landmark %>
              </p>
              <% } %>
            </div>
          </div>
        </div>

        <div class="flex gap-2 shrink-0 pt-1">
          <button onclick="editAddress('<%= addr._id %>')" class="min-h-[44px] px-3 py-2 text-xs font-medium text-[var(--accent)] hover:bg-[var(--accent-light)] rounded-lg transition-colors btn-press">Edit</button>
          <button onclick="deleteAddress('<%= addr._id %>')" class="min-h-[44px] px-3 py-2 text-xs font-medium text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors btn-press">Remove</button>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <div class="flex flex-col items-center justify-center py-20">
    <i class="fa-solid fa-location-dot text-5xl text-gray-300 mb-4"></i>
    <h3 class="text-lg font-semibold text-gray-500">No addresses saved</h3>
    <button onclick="openAddressModal()" class="mt-4 text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)] transition-colors">Add Your First Address</button>
  </div>
  <% } %>
</div>

<div id="addressModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeAddressModal()"></div>
  <div class="relative bg-white rounded-2xl shadow-xl w-full max-w-lg mx-4 p-8 max-h-[90vh] overflow-y-auto">
    <button type="button" onclick="closeAddressModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors btn-press">
      <i class="fa-solid fa-xmark text-lg"></i>
    </button>
    <h2 id="addressModalTitle" class="text-xl font-bold text-gray-900 mb-6">Add Address</h2>
    <form id="addressForm" class="space-y-4">
      <input type="hidden" name="addressId" id="addressId">
      <div>
        <label for="contactName" class="block text-sm font-medium text-gray-700">Full Name</label>
        <input type="text" name="contactName" id="contactName" required class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
      </div>
      <div>
        <label for="contactNumber" class="block text-sm font-medium text-gray-700">Phone Number</label>
        <input type="text" name="contactNumber" id="contactNumber" required inputmode="numeric" autocomplete="tel" class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
      </div>
      <div>
        <label for="pincode" class="block text-sm font-medium text-gray-700">Pincode</label>
        <input type="text" name="pincode" id="pincode" required inputmode="numeric" autocomplete="postal-code" class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
      </div>
      <div>
        <label for="building" class="block text-sm font-medium text-gray-700">Building / Apartment</label>
        <input type="text" name="building" id="building" required class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
      </div>
      <div>
        <label for="street" class="block text-sm font-medium text-gray-700">Street</label>
        <input type="text" name="street" id="street" required class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
      </div>
      <div>
        <label for="landmark" class="block text-sm font-medium text-gray-700">Landmark <span class="text-gray-400 font-normal">(optional)</span></label>
        <input type="text" name="landmark" id="landmark" class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="district" class="block text-sm font-medium text-gray-700">City / District</label>
          <input type="text" name="district" id="district" required class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
        </div>
        <div>
          <label for="state" class="block text-sm font-medium text-gray-700">State</label>
          <input type="text" name="state" id="state" required class="mt-1 block w-full rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
        </div>
      </div>
      <button type="submit" class="w-full rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors btn-press">Save Address</button>
    </form>
  </div>
</div>

<% blocks.scripts=` <script src="/javascript/user/userAddress.js"></script>` %>