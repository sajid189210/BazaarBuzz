<% blocks.head=` <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/javascript/ntc.js"></script>
    <style>.cart-color{display:inline-flex;align-items:center;gap:4px;white-space:nowrap}.cart-color-dot{display:inline-block;width:12px;height:12px;border-radius:50%;border:1px solid #d1d5db;flex-shrink:0;background:#e5e7eb}</style>` %><div
        class="mx-auto max-w-[1400px] px-3 xs:px-4 sm:px-6 lg:px-8 pt-3 xs:pt-4 sm:pt-6 pb-16">
        <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-6"> <a href="/"
                class="hover:text-[var(--accent)] transition-colors btn-press">Home</a> <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i> <span class="text-gray-800 font-medium">Cart</span> </nav>
        <h1 class="text-xl xs:text-2xl font-bold text-gray-900 mb-4 xs:mb-6">Shopping Cart</h1>
        <div class="lg:flex lg:gap-10">
            <div class="flex-1 min-w-0 max-h-none lg:max-h-[calc(100dvh-280px)] overflow-y-auto">
                <% if(cart && cart.items && cart.items.length> 0) { %> <div class="space-y-4">
                        <% cart.items.forEach((item, index)=> { const prod = item.product || {}; const offer =
                            item.offer || null; const finalUnitPrice = item.discountedPrice || prod.productPrice; const
                            subtotal = finalUnitPrice * item.quantity; %> <div
                                class="flex gap-3 xs:gap-4 p-3 xs:p-4 rounded-xl border border-gray-200 bg-white hover:border-gray-300 transition-colors"
                                data-item-id="<%= item._id %>"> <a href="/user/viewProduct?productId=<%= prod._id %>"
                                    class="shrink-0 w-20 xs:w-24 h-28 xs:h-32 rounded-lg overflow-hidden bg-gray-50"> <img
                                        src="<%= prod.images?.[0] || '/images/placeholder.jpg' %>"
                                        alt="<%= prod.productName %>" class="w-full h-full object-cover" /> </a>
                                <div class="flex-1 min-w-0 flex flex-col justify-between">
                                    <div>
                                        <div class="flex items-start justify-between gap-2">
                                            <div>
                                                <p class="text-[11px] xs:text-xs sm:text-sm text-gray-400 uppercase tracking-widest">
                                                    <%= prod.brand || 'BazaarBuzz' %>
                                                </p> <a href="/user/viewProduct?productId=<%= prod._id %>"
                                                    class="text-sm font-medium text-gray-900 hover:text-[var(--accent)] transition-colors">
                                                    <%= prod.productName %>
                                                </a>
                                             </div> <button onclick="removeItem('<%= item._id %>')"
                                                class="shrink-0 w-9 h-9 flex items-center justify-center text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors btn-press">
                                                <i class="fa-regular fa-trash-can"></i> </button>
                                        </div>
<p class="text-[11px] xs:text-xs sm:text-sm text-gray-400 mt-1">
                                                Size: <%= item.selectedSize || 'N/A' %> &middot;                                                 <span class="cart-color" data-color="<%= item.selectedColor || '' %>">
                                                    <span class="cart-color-dot"></span>
                                                    <span class="cart-color-name"><%= item.selectedColor || 'N/A' %></span>
                                                </span>
                                            </p>
                                                <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-1">
                                                    <% if(prod.productPrice !==finalUnitPrice) { %> <span
                                                            class="text-sm font-semibold text-[var(--accent)]">₹<%=
                                                                finalUnitPrice.toLocaleString('en-IN') %></span> <span
                                                            class="text-sm text-gray-400 line-through">₹<%=
                                                                prod.productPrice.toLocaleString('en-IN') %></span>
                                                        <% if(prod.discount> 0 && offer && offer.discount > 0) { %>
                                                            <span
                                                                class="text-[10px] xs:text-xs text-green-600 font-semibold bg-green-50 px-1.5 py-0.5 rounded whitespace-nowrap">
                                                                <%= prod.discount %>% + <%= offer.discount %>% off
                                                            </span>
                                                            <% } else if(prod.discount> 0) { %> <span
                                                                    class="text-[10px] xs:text-xs text-green-600 font-semibold bg-green-50 px-1.5 py-0.5 rounded whitespace-nowrap">
                                                                    <%= prod.discount %>% off
                                                                </span>
                                                                <% } else if(offer && offer.discount> 0) { %> <span
                                                                        class="text-[10px] xs:text-xs text-green-600 font-semibold bg-green-50 px-1.5 py-0.5 rounded whitespace-nowrap">
                                                                        <%= offer.offerName || 'Offer' %>
                                                                            <%= offer.discount %>% off
                                                                    </span>
                                                                    <% } %>
                                                                        <% } else { %> <span
                                                                                class="text-sm font-semibold text-gray-900">₹
                                                                                <%= finalUnitPrice.toLocaleString('en-IN') %>
                                                                                    </span>
                                                                            <% } %>
                                                </div>
                                                <% if(prod.productPrice !==finalUnitPrice) { %>
                                                    <div class="mt-1.5 space-y-0.5">
                                                        <p class="text-[11px] xs:text-xs sm:text-sm text-gray-400"> MRP <span
                                                                class="line-through">₹<%=
                                                                    prod.productPrice.toLocaleString('en-IN') %></span>
                                                            <% if(prod.discount> 0) { %> <span
                                                                    class="text-green-600">&middot; -<%= prod.discount
                                                                        %>% product discount</span>
                                                                 <% } %>
                                                         </p>
                                                         <% if(offer && offer.discount> 0) { %> <p
                                                                 class="text-[11px] xs:text-xs sm:text-sm text-green-600"> + <%=
                                                                     offer.offerName %> -<%= offer.discount %>% brand
                                                                         offer </p>
                                                             <% } %>
                                                                 <p class="text-[11px] xs:text-xs sm:text-sm font-medium text-gray-500">You
                                                                     save ₹<%= ((prod.productPrice - finalUnitPrice) *
                                                                         item.quantity).toLocaleString('en-IN') %> on this item
                                                                 </p>
                                                    </div>
                                                    <% } %>
                                    </div>
                                    <div class="flex items-center justify-between mt-3">
                                        <div class="flex items-center gap-1"> <button
                                                onclick="updateQuantity('<%= item._id %>', -1)"
                                                class="w-8 xs:w-9 h-8 xs:h-9 rounded-md border border-gray-300 flex items-center justify-center text-gray-500 hover:border-gray-400 transition-colors text-sm btn-press">&minus;</button>
                                            <span
                                                class="w-8 xs:w-10 text-center text-sm font-medium text-gray-900 quantity-display">
                                                <%= item.quantity %>
                                            </span> <button onclick="updateQuantity('<%= item._id %>', 1)"
                                                class="w-8 xs:w-9 h-8 xs:h-9 rounded-md border border-gray-300 flex items-center justify-center text-gray-500 hover:border-gray-400 transition-colors text-sm btn-press">+</button>
                                        </div>
                                        <div class="flex items-center gap-2">
                                            <% if(prod.productPrice !==finalUnitPrice) { %> <span
                                                    class="text-xs text-gray-400 line-through">₹<%= (prod.productPrice *
                                                        item.quantity).toLocaleString('en-IN') %></span>
                                                <% } %>
                                                    <p class="text-sm font-semibold text-gray-900 item-subtotal">₹<%=
                                                            subtotal.toLocaleString('en-IN') %>
                                                    </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <div class="flex flex-col items-center justify-center py-20"> <i class="fa-solid fa-cart-shopping text-5xl text-gray-300 mb-4"></i>
                            <h3 class="text-lg font-semibold text-gray-500">Your cart is empty</h3> <a
                                href="/user/getProductList/all"
                                class="mt-4 text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)] transition-colors btn-press">Continue
                                Shopping</a>
                        </div>
                        <% } %>
            </div>
            <% if(cart && cart.items && cart.items.length> 0) { %> <div class="lg:w-96 mt-8 lg:mt-0">
                    <div class="sticky top-24 rounded-xl border border-gray-200 bg-white p-5 xs:p-6">
                        <h2 class="text-base font-semibold text-gray-900 mb-4">Order Summary</h2>
                        <div class="space-y-3 text-sm">
                            <div class="flex justify-between text-gray-600"> <span>Subtotal</span> <span
                                    id="subtotalAmount">₹<%= (subTotal || 0).toLocaleString('en-IN') %></span> </div>
                            <% if(totalDiscount && totalDiscount> 0) { %> <div
                                    class="flex justify-between text-gray-600"> <span>Discount</span> <span
                                        class="text-green-600 font-medium">&minus; ₹<%= totalDiscount.toLocaleString('en-IN')
                                            %></span> </div>
                                <% } %>
                                    <div class="flex justify-between text-gray-600"> <span>Shipping</span> <span
                                            class="text-green-600 font-medium">Free</span> </div>
                                    <div class="flex justify-between text-gray-600"> <span>Tax (5%)</span> <span>₹<%=
                                                (taxAmount || 0).toLocaleString('en-IN') %></span> </div>
                                    <hr class="border-gray-100">
                                    <div class="flex justify-between text-base font-semibold text-gray-900">
                                        <span>Total</span> <span id="totalAmount">₹<%= (total || subTotal ||
                                                0).toLocaleString('en-IN') %></span> </div>
                        </div> <a href="/user/checkout"
                            class="mt-6 block w-full rounded-lg bg-gray-900 px-4 py-3 text-sm font-semibold text-white text-center hover:bg-gray-800 transition-colors btn-press">Proceed
                            to Checkout</a> <a href="/user/getProductList/all"
                            class="mt-3 block text-center text-sm text-[var(--accent)] hover:text-[var(--accent)] transition-colors btn-press">Continue
                            Shopping</a>
                    </div>
                </div>
                <% } %>
        </div>
    </div>
    <% blocks.scripts=` <script src="/javascript/user/userCart.js">
        </script>` %>