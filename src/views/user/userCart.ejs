<% layout('layout') -%>
<% blocks.head = `
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
` %>

<div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 pt-6 pb-16">
    <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-rose-500 transition-colors">Home</a>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-gray-800 font-medium">Cart</span>
    </nav>

    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-8">Shopping Cart</h1>

    <div class="lg:flex lg:gap-10">
        <div class="flex-1 min-w-0">
            <% if(cart && cart.items && cart.items.length > 0) { %>
            <div class="space-y-4">
                <% cart.items.forEach((item, index) => {
                    const prod = item.product || {};
                    const offer = item.offer || null;
                    const finalUnitPrice = item.discountedPrice || prod.productPrice;
                    const subtotal = finalUnitPrice * item.quantity;
                %>
                <div class="flex gap-4 p-4 rounded-xl border border-gray-200 bg-white hover:border-gray-300 transition-colors" data-item-id="<%= item._id %>">
                    <a href="/user/viewProduct?productId=<%= prod._id %>" class="shrink-0 w-24 h-32 rounded-lg overflow-hidden bg-gray-50">
                        <img src="<%= prod.images?.[0] || '/images/placeholder.jpg' %>" alt="<%= prod.productName %>" class="w-full h-full object-cover" />
                    </a>
                    <div class="flex-1 min-w-0 flex flex-col justify-between">
                        <div>
                            <div class="flex items-start justify-between gap-2">
                                <div>
                                    <p class="text-xs text-gray-400 uppercase tracking-widest"><%= prod.brand || 'BazaarBuzz' %></p>
                                    <a href="/user/viewProduct?productId=<%= prod._id %>" class="text-sm font-medium text-gray-900 hover:text-rose-500 transition-colors"><%= prod.productName %></a>
                                </div>
                                <button onclick="removeItem('<%= item._id %>')" class="shrink-0 text-gray-400 hover:text-red-500 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                </button>
                            </div>
                            <% if(prod.size && prod.size.length > 0) { %>
                            <p class="text-xs text-gray-400 mt-1">Size: <%= item.selectedSize || 'N/A' %></p>
                            <% } %>
                            <div class="flex items-center gap-2 mt-1">
                                <% if(prod.productPrice !== finalUnitPrice) { %>
                                <span class="text-sm font-semibold text-rose-500">₹<%= finalUnitPrice.toLocaleString() %></span>
                                <span class="text-sm text-gray-400 line-through">₹<%= prod.productPrice.toLocaleString() %></span>
                                <% if(prod.discount > 0 && offer && offer.discount > 0) { %>
                                <span class="text-[10px] font-semibold text-green-600 bg-green-50 px-1.5 py-0.5 rounded"><%= prod.discount %>% + <%= offer.discount %>% off</span>
                                <% } else if(prod.discount > 0) { %>
                                <span class="text-[10px] font-semibold text-green-600 bg-green-50 px-1.5 py-0.5 rounded"><%= prod.discount %>% off</span>
                                <% } else if(offer && offer.discount > 0) { %>
                                <span class="text-[10px] font-semibold text-green-600 bg-green-50 px-1.5 py-0.5 rounded"><%= offer.offerName || 'Offer' %> <%= offer.discount %>% off</span>
                                <% } %>
                                <% } else { %>
                                <span class="text-sm font-semibold text-gray-900">₹<%= finalUnitPrice.toLocaleString() %></span>
                                <% } %>
                            </div>
                            <% if(prod.productPrice !== finalUnitPrice) { %>
                            <div class="mt-1.5 space-y-0.5">
                                <p class="text-[11px] text-gray-400">
                                    MRP <span class="line-through">₹<%= prod.productPrice.toLocaleString() %></span>
                                    <% if(prod.discount > 0) { %>
                                    <span class="text-green-600">&middot; -<%= prod.discount %>% product discount</span>
                                    <% } %>
                                </p>
                                <% if(offer && offer.discount > 0) { %>
                                <p class="text-[11px] text-green-600">
                                    + <%= offer.offerName %> -<%= offer.discount %>% brand offer
                                </p>
                                <% } %>
                                <p class="text-[11px] font-medium text-gray-500">You save ₹<%= ((prod.productPrice - finalUnitPrice) * item.quantity).toLocaleString() %> on this item</p>
                            </div>
                            <% } %>
                        </div>
                        <div class="flex items-center justify-between mt-3">
                            <div class="flex items-center gap-1">
                                <button onclick="updateQuantity('<%= item._id %>', -1)" class="w-7 h-7 rounded-md border border-gray-300 flex items-center justify-center text-gray-500 hover:border-gray-400 transition-colors text-sm">&minus;</button>
                                <span class="w-8 text-center text-sm font-medium text-gray-900 quantity-display"><%= item.quantity %></span>
                                <button onclick="updateQuantity('<%= item._id %>', 1)" class="w-7 h-7 rounded-md border border-gray-300 flex items-center justify-center text-gray-500 hover:border-gray-400 transition-colors text-sm">+</button>
                            </div>
                            <div class="flex items-center gap-2">
                                <% if(prod.productPrice !== finalUnitPrice) { %>
                                <span class="text-xs text-gray-400 line-through">₹<%= (prod.productPrice * item.quantity).toLocaleString() %></span>
                                <% } %>
                                <p class="text-sm font-semibold text-gray-900 item-subtotal">₹<%= subtotal.toLocaleString() %></p>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } else { %>
            <div class="flex flex-col items-center justify-center py-20">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-gray-300 mb-4"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                <h3 class="text-lg font-semibold text-gray-500">Your cart is empty</h3>
                <a href="/user/productList" class="mt-4 text-sm font-medium text-rose-500 hover:text-rose-600 transition-colors">Continue Shopping</a>
            </div>
            <% } %>
        </div>

        <% if(cart && cart.items && cart.items.length > 0) { %>
        <div class="lg:w-96 mt-8 lg:mt-0">
            <div class="sticky top-24 rounded-xl border border-gray-200 bg-white p-6">
                <h2 class="text-base font-semibold text-gray-900 mb-4">Order Summary</h2>
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between text-gray-600">
                        <span>Subtotal</span>
                        <span id="subtotalAmount">₹<%= (subTotal || 0).toLocaleString() %></span>
                    </div>
                    <% if(totalDiscount && totalDiscount > 0) { %>
                    <div class="flex justify-between text-gray-600">
                        <span>Discount</span>
                        <span class="text-green-600 font-medium">&minus; ₹<%= totalDiscount.toLocaleString() %></span>
                    </div>
                    <% } %>
                    <div class="flex justify-between text-gray-600">
                        <span>Shipping</span>
                        <span class="text-green-600 font-medium">Free</span>
                    </div>
                    <div class="flex justify-between text-gray-600">
                        <span>Tax (5%)</span>
                        <span>₹<%= (taxAmount || 0).toLocaleString() %></span>
                    </div>
                    <hr class="border-gray-100">
                    <div class="flex justify-between text-base font-semibold text-gray-900">
                        <span>Total</span>
                        <span id="totalAmount">₹<%= (total || subTotal || 0).toLocaleString() %></span>
                    </div>
                </div>
                <a href="/user/checkout" class="mt-6 block w-full rounded-lg bg-gray-900 px-4 py-3 text-sm font-semibold text-white text-center hover:bg-gray-800 transition-colors">Proceed to Checkout</a>
                <a href="/user/productList" class="mt-3 block text-center text-sm text-rose-500 hover:text-rose-600 transition-colors">Continue Shopping</a>
            </div>
        </div>
        <% } %>
    </div>
</div>

<% blocks.scripts = `
    <script src="/javascript/user/userCart.js"></script>
` %>