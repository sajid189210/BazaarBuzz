                                            src="/uploads/small-purse-studio-still-life.jpg" alt="Bags" /> -->
                        <!-- Adjust size here -->
                        <!-- <div
                                            class="flex items-center justify-center absolute inset-0 bg-transparent transition duration-300 ease-in-out text-white hover:text-[#556B2F] hover:bg-[#EAF0DC] hover:bg-opacity-70">
