                                <a href="" class="">
                                    <div
                                        class="rounded-lg relative shadow-lg w-fit transition duration-500 ease-in-out hover:shadow-2xl hover:scale-105 overflow-hidden">
                                        <img class="rounded-lg w-40 h-auto transition-transform duration-500 ease-in-out hover:scale-110"
                                            src="/uploads/pair-brown-leather-boots.jpg" alt="Shoes" /> -->
                        <!-- Adjust size here -->
