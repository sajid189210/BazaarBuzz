<% blocks.head=` <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>` %><div
        class="mx-auto max-w-[1400px] px-3 xs:px-4 sm:px-6 lg:px-8 pt-4 sm:pt-6 pb-16">
        <nav class="hidden lg:flex items-center gap-2 text-sm text-gray-500 mb-8"> <a href="/"
                class="hover:text-[var(--accent)] transition-colors btn-press">Home</a> <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i> <a href="/user/cart" class="hover:text-[var(--accent)] transition-colors btn-press">Cart</a> <i class="fa-solid fa-chevron-right text-xs text-gray-400"></i> <span class="text-gray-800 font-medium">Checkout</span> </nav>
        <h1 class="text-xl xs:text-2xl font-bold text-gray-900 mb-6">Checkout</h1>
        <div class="lg:flex lg:gap-10">
            <div class="flex-1 min-w-0 space-y-6"> <!-- Address Selection -->
                <div class="rounded-xl border border-gray-200 bg-white p-4 xs:p-5">
                    <h2 class="text-sm xs:text-base font-semibold text-gray-900 mb-4">Delivery Address</h2>
                    <% if(user && user.addressId && user.addressId.length> 0) { %>
                        <input type="checkbox" id="showAllAddresses" class="hidden" />
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <% user.addressId.forEach((addr, i)=> { %> <label
                                    class="flex items-start gap-3 cursor-pointer group p-3 rounded-lg border <%= i === 0 ? 'border-gray-900 bg-gray-50' : 'border-gray-200 hover:border-gray-300' %> transition-colors <%= i >= 4 ? 'extra-addr' : '' %>">
                                    <input type="radio" name="address" value="<%= addr._id %>"
                                        class="mt-1 w-4 h-4 text-[var(--accent)] border-gray-300 focus:ring-rose-400 shrink-0"
                                        <%=i===0 ? 'checked' : '' %>> <div class="text-xs xs:text-sm">
                                        <p class="font-medium text-gray-900">
                                            <%= addr.contactName %>
                                        </p>
                                        <p class="text-gray-500 mt-0.5">
                                            <%= addr.building %>, <%= addr.street %>, <%= addr.district %>
                                                        <%= addr.pincode %>
                                        </p>
                                        <p class="text-gray-500">Phone: <%= addr.contactNumber %>
                                        </p>
                                    </div> </label>
                                <% }) %>
                        </div>
                        <% if(user.addressId.length > 4) { %>
                            <style>
                                .extra-addr { display: none; }
                                #showAllAddresses:checked ~ div .extra-addr { display: flex; }
                            </style>
                            <div class="flex justify-center mt-3">
                                <label for="showAllAddresses" id="addrToggle" class="inline-flex items-center gap-2 text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)] transition-colors cursor-pointer btn-press">
                                    Show more <i class="fa-solid fa-chevron-down text-xs"></i>
                                </label>
                            </div>
                            <script>
                                document.getElementById('showAllAddresses').addEventListener('change', function() {
                                    var toggle = document.getElementById('addrToggle');
                                    if (this.checked) {
                                        toggle.innerHTML = 'Show less <i class="fa-solid fa-chevron-up text-xs"></i>';
                                    } else {
                                        toggle.innerHTML = 'Show more <i class="fa-solid fa-chevron-down text-xs"></i>';
                                    }
                                });
                            </script>
                        <% } %>
                        <% } else { %>
                            <p class="text-sm text-gray-400">No addresses saved. Please add one.</p>
                            <% } %>
                </div>
                <div class="rounded-xl border border-gray-200 bg-white p-4 xs:p-5">
                    <h2 class="text-sm xs:text-base font-semibold text-gray-900 mb-4">Payment Method</h2>
                    <div class="space-y-3"> <label
                            class="flex items-center gap-3 cursor-pointer p-3 rounded-lg border border-gray-900 bg-gray-50 transition-colors">
                            <input type="radio" name="paymentMethod" value="<%= PAYMENT_SOURCE_COD %>"
                                class="w-4 h-4 text-[var(--accent)] border-gray-300 focus:ring-rose-400" checked> <span
                                class="text-sm font-medium text-gray-900">Cash on Delivery</span> </label>
                        <label
                                class="flex items-center gap-3 cursor-pointer p-3 rounded-lg border border-gray-200 hover:border-gray-300 transition-colors">
                                <input type="radio" name="paymentMethod" value="<%= PAYMENT_SOURCE_WALLET %>"
                                    class="w-4 h-4 text-[var(--accent)] border-gray-300 focus:ring-rose-400">
                                <span class="flex-1 flex items-center justify-between text-sm font-medium text-gray-900">
                                    <span>Wallet</span>
                                    <% if(wallet && wallet.balance > 0) { %>
                                        <span>Balance: ₹<%= wallet.balance.toLocaleString() %></span>
                                    <% } else { %>
                                        <span class="text-red-500 text-xs font-semibold">No funds</span>
                                    <% } %>
                                </span> </label> <label
                                    class="flex items-center gap-3 cursor-pointer p-3 rounded-lg border border-gray-200 hover:border-gray-300 transition-colors">
                                    <input type="radio" name="paymentMethod" value="<%= PAYMENT_SOURCE_RAZORPAY %>"
                                        class="w-4 h-4 text-[var(--accent)] border-gray-300 focus:ring-rose-400"> <span
                                        class="text-sm font-medium text-gray-900">Razorpay</span> </label>
                    </div>
                    <hr class="border-gray-100 my-5">
                    <h2 class="text-sm xs:text-base font-semibold text-gray-900 mb-4">Apply Coupon</h2>
                    <div class="flex gap-2 xs:gap-3"> <input type="text" id="couponCode" placeholder="Enter coupon code"
                            class="flex-1 rounded-lg border border-gray-300 bg-white px-3 xs:px-4 py-2.5 text-xs xs:text-sm text-gray-900 placeholder:text-gray-400 focus:border-rose-400 focus:ring-2 focus:ring-rose-400/20 outline-none transition-all" />
                        <button onclick="applyCoupon()" type="button"
                            class="rounded-lg bg-gray-900 px-4 xs:px-5 py-2.5 text-xs xs:text-sm font-semibold text-white hover:bg-gray-800 transition-colors btn-press">Apply</button>
                    </div>
                    <div id="couponMessage" class="mt-2 text-[10px] xs:text-xs"></div>
                </div> <button onclick="placeOrder()" type="button"
                    class="w-full rounded-lg bg-gray-900 px-6 py-3 text-sm font-semibold text-white hover:bg-gray-800 transition-colors btn-press">Place
                    Order</button>
            </div> <!-- Order Summary Sidebar -->
            <div class="lg:w-96 mt-8 lg:mt-0">
                <div class="sticky top-24 rounded-xl border border-gray-200 bg-white p-4 xs:p-5">
                    <h2 class="text-sm xs:text-base font-semibold text-gray-900 mb-4">Order Summary</h2>
                    <div class="space-y-4">
                        <% if(cart && cart.items && cart.items.length> 0) { %> <% cart.items.forEach(item=> { const prod
                                = item.product || {}; const discPrice = prod.discount ? Math.round(prod.productPrice -
                                (prod.productPrice * prod.discount / 100)) : prod.productPrice; %> <div
                                    class="flex gap-2 xs:gap-3">
                                    <div class="w-12 xs:w-14 h-12 xs:h-14 rounded-lg overflow-hidden bg-gray-50 shrink-0"> <img
                                            src="<%= prod.images?.[0] || '/images/placeholder.jpg' %>" alt=""
                                            class="w-full h-full object-cover" /> </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-[10px] xs:text-xs font-medium text-gray-900 truncate">
                                            <%= prod.productName %>
                                        </p>
                                        <p class="text-[10px] xs:text-xs text-gray-500">Qty: <%= item.quantity %>
                                        </p>
                                        <p class="text-[10px] xs:text-xs font-semibold text-gray-900">₹<%= (discPrice *
                                                item.quantity).toLocaleString('en-IN') %>
                                        </p>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } %>
                                        <hr class="border-gray-100">
                                        <div class="space-y-2 text-xs xs:text-sm">
                                            <div class="flex justify-between text-gray-600">
                                                <span>Subtotal</span>
                                                <span>₹<%= (subTotal || 0).toLocaleString('en-IN') %></span>
                                            </div>
                                            <% const productDiscount = (totalDiscount || 0) - ((cart && cart.discountedValue) || 0); %>
                                            <div class="flex justify-between <%- productDiscount > 0 ? 'text-green-600' : 'text-gray-400' %>">
                                                <span>Discount</span>
                                                <span><%= productDiscount > 0 ? '-' : '' %> ₹<%= productDiscount.toLocaleString('en-IN') %></span>
                                            </div>
                                            <div id="couponDiscountRow" class="<%= (cart && cart.discountedValue > 0) ? '' : 'hidden' %> flex justify-between text-green-600">
                                                <span>Coupon Discount</span>
                                                <span>&minus; ₹<span id="couponDiscountAmount"><%= ((cart && cart.discountedValue) || 0).toLocaleString('en-IN') %></span></span>
                                            </div>
                                            <div class="flex justify-between text-gray-600">
                                                <span>Shipping</span>
                                                <span class="text-green-600">Free</span>
                                            </div>
                                            <div class="flex justify-between text-gray-600">
                                                <span>Tax (5%)</span>
                                                <span>₹<%= (taxAmount || 0).toLocaleString('en-IN') %></span>
                                            </div>
                                            <hr class="border-gray-100">
                                            <div class="flex justify-between text-sm xs:text-base font-semibold text-gray-900">
                                                <span>Total</span>
                                                <span id="checkoutTotal" data-total="<%= (total || 0).toFixed(2) %>">₹<%= (total || 0).toLocaleString('en-IN') %></span>
                                            </div>
                                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <% blocks.scripts=` <script src="/javascript/user/userCheckout.js">
        </script>` %>